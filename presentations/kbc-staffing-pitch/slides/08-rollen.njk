<!-- ════════════════ 08 · ROLLEN & PROFIELEN ════════════════ -->
  <section data-label="Rollen & profielen" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">07</span>Rollen &amp; profielen</p>
      <h2 class="h2">Profielen die zelf bouwen, <span class="accent">van engineering tot product</span>.</h2>

      <div class="roles-grid">
        <div class="role-card">
          <h4>Agentic developers</h4>
          <ul>
            <li>Agents die redeneren én uitvoeren</li>
            <li>Tool-integraties &amp; orchestratie</li>
            <li>Van prototype tot productie</li>
          </ul>
        </div>
        <div class="role-card">
          <h4>Machine learning engineers</h4>
          <ul>
            <li>Modellen trainen &amp; finetunen</li>
            <li>ML-pipelines &amp; MLOps</li>
            <li>Data als fundament</li>
          </ul>
        </div>
        <div class="role-card">
          <h4>AI engineers</h4>
          <ul>
            <li>LLM-applicaties &amp; RAG</li>
            <li>Evaluatie &amp; kwaliteitsbewaking</li>
            <li>Schaalbare AI-architectuur</li>
          </ul>
        </div>
        <div class="role-card">
          <h4>AI product managers</h4>
          <ul>
            <li>Van use-case naar roadmap</li>
            <li>Brug tussen business &amp; engineering</li>
            <li>Adoptie &amp; meetbare impact</li>
          </ul>
        </div>
      </div>

      <div class="pillrow">
        <span class="pill">Ook in ons netwerk:</span>
        <span class="pill">Data engineers</span>
        <span class="pill">Data scientists</span>
        <span class="pill">MLOps / platform engineers</span>
        <span class="pill">AI security &amp; governance-profielen</span>
        <span class="pill">en meer</span>
      </div>
    </div>
    {% set slideNumber = "08" %}
    {% set slideTotal = "16" %}
    {% include "../../shared/chrome.njk" %}
  </section>
