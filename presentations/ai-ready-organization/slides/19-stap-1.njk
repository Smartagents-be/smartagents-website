<!-- ════════════════ 19 · STAP 1 — BEDRIJFSDOELSTELLINGEN ════════════════ -->
  <section data-label="Stap 1" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <div class="step-strip">
        <span class="pill on">Stap 1 · Bedrijfsdoelstellingen</span>
        <span class="sep">→</span>
        <span class="pill">Stap 2</span>
        <span class="pill">Stap 3</span>
        <span class="pill">Stap 4</span>
        <span class="pill">Stap 5</span>
      </div>
      <h1 class="title" style="max-width: 1500px;">Vertrek vanuit wat je organisatie<br>al wil bereiken — niet vanuit AI.</h1>

      <div class="grid-2-side" style="margin-top: 28px; align-items: start;">
        <div>
          <p class="body" style="font-size: 24px; max-width: 760px;">
            AI-investeringen moeten een doel dienen dat los van AI bestaat. De eerste stap is dus geen brainstorm over tools, maar alignering binnen het directieteam over wat de organisatie écht wil bereiken.
          </p>
          <p style="font-size: 24px; margin-top: 18px; color: var(--fg); max-width: 760px; line-height: 1.45;">
            Een eenvoudig formaat: een "Hoe zouden we…"-vraag. Het dwingt scherpte over doel én KPI.
          </p>

          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-top: 28px;">
            <div style="border: 1px solid var(--sa-white-10); border-radius: 12px; padding: 20px 18px; background: var(--sa-white-05);">
              <div style="font-size: 24px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sa-cyan); margin-bottom: 8px;">Wat?</div>
              <p style="font-size: 24px; line-height: 1.4; color: var(--fg-muted); margin: 0;">Benoem en prioriteer 3–7 strategische doelen als "Hoe zouden we"-vragen.</p>
            </div>
            <div style="border: 1px solid var(--sa-white-10); border-radius: 12px; padding: 20px 18px; background: var(--sa-white-05);">
              <div style="font-size: 24px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sa-cyan); margin-bottom: 8px;">Wie?</div>
              <p style="font-size: 24px; line-height: 1.4; color: var(--fg-muted); margin: 0;">Doe deze oefening in het directieteam — voor draagvlak nadien.</p>
            </div>
            <div style="border: 1px solid var(--sa-white-10); border-radius: 12px; padding: 20px 18px; background: var(--sa-white-05);">
              <div style="font-size: 24px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sa-cyan); margin-bottom: 8px;">Hoe?</div>
              <p style="font-size: 24px; line-height: 1.4; color: var(--fg-muted); margin: 0;">Individuele voorbereiding, gevolgd door een collectieve prioriterings­workshop.</p>
            </div>
          </div>
        </div>

        <!-- "Hoe zouden we" template card -->
        <div style="border: 1px solid var(--sa-cyan-30); border-radius: 20px; padding: 32px 32px; background: var(--sa-cyan-08); position: relative;">
          <div style="font-size: 24px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--sa-cyan); margin-bottom: 18px;">Template</div>
          <div style="font-size: 28px; line-height: 1.35; color: var(--fg); font-weight: 500;">
            <span style="color: var(--fg-muted);">Hoe zouden we</span>
            <div style="margin: 8px 0; padding: 10px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--accent);">[ actie ]</div>
            <span style="color: var(--fg-muted);">voor</span>
            <div style="margin: 8px 0; padding: 10px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--accent);">[ doelgroep ]</div>
            <span style="color: var(--fg-muted);">zodat</span>
            <div style="margin: 8px 0; padding: 10px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--accent);">[ resultaat ]</div>
          </div>
        </div>
      </div>
    </div>
    {% set slideNumber = "19" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
