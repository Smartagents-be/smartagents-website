<!-- ════════════════ 25 · STAP 5 — ROADMAP ════════════════ -->
  <section data-label="Stap 5" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <div class="step-strip">
        <span class="pill">Stap 1</span><span class="pill">Stap 2</span><span class="pill">Stap 3</span><span class="pill">Stap 4</span>
        <span class="sep">→</span>
        <span class="pill on">Stap 5 · AI roadmap</span>
      </div>
      <h1 class="title" style="max-width: 1600px; font-size: 56px; margin-bottom: 20px;">Vertaal de keuzes naar acties<br>op de drie niveaus.</h1>

      <!-- 3-lane swimlane -->
      <div style="margin-top: 8px; display: flex; flex-direction: column; gap: 10px;">
        <div style="display: grid; grid-template-columns: 280px 1fr; gap: 16px; align-items: stretch;">
          <div style="padding: 20px 28px; border-radius: 14px; background: var(--sa-cyan-08); border: 1px solid var(--sa-cyan-30); display: flex; flex-direction: column; justify-content: center; gap: 6px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Niveau 01</div>
            <div style="font-size: 30px; font-weight: 600; color: var(--fg);">Strategie</div>
            <div style="font-size: 24px; color: var(--fg-muted);">Visie · KPI's · beleid</div>
          </div>
          <div style="border-radius: 14px; background: var(--sa-white-05); border: 1px solid var(--sa-white-10); display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; padding: 14px;">
            <div style="padding: 14px 16px; border-radius: 10px; background: var(--sa-cyan-15); border: 1px solid var(--sa-cyan-30); font-size: 24px; color: var(--fg);">AI-visie publiceren</div>
            <div style="padding: 14px 16px; border-radius: 10px; background: var(--sa-cyan-08); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--fg-muted);">KPI-set bepalen</div>
            <div style="padding: 14px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-10); font-size: 24px; color: var(--fg-muted);">AI-beleid uitwerken</div>
            <div></div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 280px 1fr; gap: 16px; align-items: stretch;">
          <div style="padding: 20px 28px; border-radius: 14px; background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.3); display: flex; flex-direction: column; justify-content: center; gap: 6px;">
            <div style="font-size: 24px; font-weight: 700; color: #a78bfa; letter-spacing: 0.18em; text-transform: uppercase;">Niveau 02</div>
            <div style="font-size: 30px; font-weight: 600; color: var(--fg);">Verandermotor</div>
            <div style="font-size: 24px; color: var(--fg-muted);">Change · communicatie · opleiding</div>
          </div>
          <div style="border-radius: 14px; background: var(--sa-white-05); border: 1px solid var(--sa-white-10); display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; padding: 14px;">
            <div></div>
            <div style="padding: 14px 16px; border-radius: 10px; background: rgba(167,139,250,0.18); border: 1px solid rgba(167,139,250,0.4); font-size: 24px; color: var(--fg);">Kick-off team</div>
            <div style="padding: 14px 16px; border-radius: 10px; background: rgba(167,139,250,0.08); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--fg-muted);">Train-the-trainer</div>
            <div style="padding: 14px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-10); font-size: 24px; color: var(--fg-muted);">Rolling enablement</div>
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 280px 1fr; gap: 16px; align-items: stretch;">
          <div style="padding: 20px 28px; border-radius: 14px; background: rgba(34,211,238,0.10); border: 1px solid rgba(34,211,238,0.3); display: flex; flex-direction: column; justify-content: center; gap: 6px;">
            <div style="font-size: 24px; font-weight: 700; color: #22d3ee; letter-spacing: 0.18em; text-transform: uppercase;">Niveau 03</div>
            <div style="font-size: 30px; font-weight: 600; color: var(--fg);">Enablers</div>
            <div style="font-size: 24px; color: var(--fg-muted);">Talent · governance · data · proces · tech</div>
          </div>
          <div style="border-radius: 14px; background: var(--sa-white-05); border: 1px solid var(--sa-white-10); display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; padding: 14px;">
            <div style="padding: 14px 16px; border-radius: 10px; background: rgba(34,211,238,0.18); border: 1px solid rgba(34,211,238,0.4); font-size: 24px; color: var(--fg);">Datalaag opzetten</div>
            <div style="padding: 14px 16px; border-radius: 10px; background: rgba(34,211,238,0.08); border: 1px dashed var(--sa-white-25); font-size: 24px; color: var(--fg-muted);">Governance-board</div>
            <div></div>
            <div style="padding: 14px 16px; border-radius: 10px; background: var(--sa-white-05); border: 1px dashed var(--sa-white-10); font-size: 24px; color: var(--fg-muted);">Pilot 1 live</div>
          </div>
        </div>

        <!-- Time axis -->
        <div style="display: grid; grid-template-columns: 280px 1fr; gap: 16px; margin-top: 4px;">
          <div></div>
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; padding: 0 14px; font-size: 24px; color: var(--fg-subtle); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600;">
            <span>Q1</span><span>Q2</span><span>Q3</span><span>Q4 →</span>
          </div>
        </div>
      </div>

    </div>
    {% set slideNumber = "25" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
