<!-- ════════════════ 06 · ADOPTIE ≠ WAARDE ════════════════ -->
  <section data-label="Adoptie stats" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Adoptie ≠ waarde</p>
      <h1 class="title" style="max-width: 1500px;">Persoonlijke productiviteit is niet<br>hetzelfde als <span class="accent">bedrijfswaarde</span>.</h1>
      <p class="body" style="margin-top: 8px; max-width: 1400px;">
        Recent onderzoek toont indrukwekkende adoptiecijfers. Bijna de helft van de Vlamingen gebruikt actief generatieve AI, en zes op de tien bedrijven heeft minstens één AI-toepassing in gebruik. Maar adoptie is geen doel.
      </p>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-top: 72px;">
        <div>
          <div class="stat">43<span class="unit">%</span></div>
          <p class="stat-desc">van de Vlamingen beschouwt zichzelf in 2025 als een <span class="ink">actieve gebruiker</span> van generatieve AI.</p>
          <p class="source">Bron · imec digimeter, 2025</p>
        </div>
        <div>
          <div class="stat">60<span class="unit">%</span></div>
          <p class="stat-desc">van de bedrijven gebruikt vandaag <span class="ink">minstens één AI-technologie</span> in de werking.</p>
          <p class="source">Bron · VLAIO, 2025</p>
        </div>
      </div>
    </div>
    {% set slideNumber = "06" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
