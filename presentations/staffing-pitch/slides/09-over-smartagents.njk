<!-- ════════════════ 09 · OVER SMARTAGENTS / CTA ════════════════ -->
  <section data-label="Over SmartAgents" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">08</span>Over SmartAgents</p>
      <h1 class="title" style="max-width: 1500px; font-size: 58px;">Je lokale partner<br>voor <span class="accent">AI-talent en -impact</span>.</h1>

      <div style="display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 46px; margin-top: 24px; align-items: center;">
        <div style="display: flex; flex-direction: column; justify-content: center; max-width: 560px;">
          <p class="body" style="font-size: 27px; line-height: 1.5; max-width: 560px;">
            SmartAgents is opgericht in 2026 en combineert <strong style="color: var(--fg);">technische diepgang</strong> met een <strong style="color: var(--fg);">pragmatische aanpak</strong>. Wij bouwen zelf <strong style="color: var(--fg);">AI-agents en automatisaties</strong>, en weten daardoor precies welke mensen jouw organisatie nodig heeft, hoe je ze herkent, aantrekt en laat groeien.
          </p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 16px;">
          <div class="founder" style="min-height: 184px;">
            <div class="photo" style="background-image: url('assets/axel-profile.webp');"></div>
            <div class="info" style="padding: 24px 28px;">
              <div class="role">Founder</div>
              <h3>Axel Segers</h3>
              <p>Digitale transformatie · Strategie · Ondernemerschap · AI-adoptie.</p>
            </div>
          </div>
          <div class="founder" style="min-height: 184px;">
            <div class="photo" style="background-image: url('assets/tom-profile.webp');"></div>
            <div class="info" style="padding: 24px 28px;">
              <div class="role">Founder</div>
              <h3>Tom Haeldermans</h3>
              <p>Technische architectuur, AI-engineering en implementatie.</p>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top: 56px; display: grid; grid-template-columns: 1.05fr 0.95fr 0.65fr; gap: 30px; align-items: center; padding: 22px 28px; border-radius: 20px; background: #0f172a; box-shadow: 0 20px 50px rgba(15,23,42,0.16);">
        <div>
          <div style="font-size: 18px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #00d8ff; margin-bottom: 8px;">Laten we beginnen</div>
          <div style="font-size: 34px; line-height: 1.08; color: #f8fafc; font-weight: 600; letter-spacing: -0.02em;">Op zoek naar AI-talent?</div>
          <div style="font-size: 20px; line-height: 1.3; color: #94a3b8; margin-top: 8px;">Vertel ons welke expertise je zoekt, wij vinden de mensen die je vooruithelpen.</div>
        </div>
        <div>
          <div style="font-size: 18px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #00d8ff; margin-bottom: 8px;">Contact</div>
          <div style="font-size: 24px; color: #f8fafc; font-weight: 500;">info@smartagents.be</div>
          <div style="font-size: 21px; color: #94a3b8; margin-top: 6px;">smartagents.be</div>
        </div>
        <div>
          <div style="font-size: 18px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #00d8ff; margin-bottom: 8px;">Info</div>
          <div style="font-size: 22px; color: #f8fafc; font-weight: 500;">Beringen, België</div>
          <div style="font-size: 18px; color: #94a3b8; margin-top: 6px;">BE1037.114.694</div>
        </div>
      </div>
    </div>
    {% set slideNumber = "09" %}
    {% set slideTotal = "09" %}
    {% include "../../shared/chrome.njk" %}
  </section>
