<section data-label="24 Voorbeeld 08 · CV-matching">
  <div class="slide-frame split">

    <div style="flex: 0 0 700px; padding: var(--pad-top) 64px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column;">
      <div style="display: flex; align-items: baseline; gap: 20px;">
        <span style="font-size: 88px; font-weight: 500; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; letter-spacing: -0.03em;">08</span>
        <span class="eyebrow">Voorbeeld</span>
      </div>
      <div class="bs-pills" style="margin-top: 20px;">
        <span class="bs-pill" style="--c: #06b6d4;">LLM</span>
        <span class="bs-pill" style="--c: #4f6cf7;">RAG</span>
        <span class="bs-pill" style="--c: #f59e0b;">Tools</span>
      </div>
      <h2 class="title" style="margin-top: 22px; font-size: 58px;">CV-matching tegen jouw functieprofiel.</h2>
      <p class="body" style="margin-top: 24px;">
        De agent leest élk cv, scoort het tegen jouw functieprofiel en motiveert per kandidaat. Hij kan ook LinkedIn en andere platformen afspeuren naar geschikte profielen.
      </p>
    </div>

    <div style="flex: 1; background: var(--bg-alt); padding: 56px 72px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 24px;">

      <!-- the profile we match against -->
      <div style="width: 100%; max-width: 820px; background: color-mix(in srgb, var(--accent-3) 8%, var(--surface)); border: 2px solid var(--accent-3); border-radius: 20px; box-shadow: 0 14px 36px color-mix(in srgb, var(--accent-3) 22%, transparent); padding: 24px 30px;">
        <div style="display: flex; align-items: center; gap: 10px;">
          <span style="display: inline-flex; align-items: center; gap: 8px; font-size: 19px; font-weight: 700; color: var(--accent-3); text-transform: uppercase; letter-spacing: 0.08em;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Functieprofiel
          </span>
        </div>
        <div style="font-size: 26px; font-weight: 700; color: var(--ink); margin-top: 10px;">Senior Python developer · finance</div>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px;">
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 8px 16px; font-size: 21px; font-weight: 600;">Python</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 8px 16px; font-size: 21px; font-weight: 600;">Finance-ervaring</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 8px 16px; font-size: 21px; font-weight: 600;">5+ jaar</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 8px 16px; font-size: 21px; font-weight: 600;">Drietalig</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 8px 16px; font-size: 21px; font-weight: 600;">Teamlead-potentieel</span>
        </div>
      </div>

      <!-- the ranking + the why -->
      <div style="width: 100%; max-width: 820px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 24px; box-shadow: 0 20px 50px rgba(15,23,42,0.10); overflow: hidden;">

        <!-- header + funnel -->
        <div style="display: flex; align-items: center; gap: 18px; padding: 22px 30px; border-bottom: 1px solid var(--border-soft);">
          <span style="display: inline-flex; align-items: center; gap: 9px; font-size: 21px; font-weight: 700; color: var(--accent);">
            <span style="width: 11px; height: 11px; border-radius: 999px; background: var(--accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent);"></span>
            CV-matching
          </span>
          <div style="flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 14px; font-size: 20px; color: var(--ink-4);">
            <span>cv's + LinkedIn</span>
            <span>→</span>
            <span><b style="color: var(--ink-2);">132</b> gescoord</span>
            <span>→</span>
            <span style="color: var(--accent); font-weight: 700;">top 5</span>
          </div>
        </div>

        <!-- top candidate, expanded with the why -->
        <div style="padding: 24px 30px; border-bottom: 1px solid var(--border-soft); background: color-mix(in srgb, var(--accent) 4%, transparent);">
          <div style="display: flex; align-items: flex-start; gap: 18px;">
            <div style="width: 46px; height: 46px; border-radius: 999px; background: var(--accent); color: #fff; font-size: 18px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">SK</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 25px; font-weight: 700; color: var(--ink); line-height: 1.2;">Sofia Kowalski</div>
              <div style="font-size: 20px; color: var(--ink-4); margin-top: 4px;">7 jaar · ex-Belfius · drietalig</div>
            </div>
            <div style="text-align: right; flex-shrink: 0;">
              <div style="font-size: 40px; font-weight: 700; color: var(--accent); line-height: 1;">94</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">match</div>
            </div>
          </div>
          <!-- per-criterion match against the profile -->
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px;">
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Python</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Finance-ervaring</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>7 jaar</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Drietalig</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: rgba(180,83,9,0.12); color: var(--accent-warm); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>Teamlead-potentieel</span>
          </div>
          <div style="font-size: 20px; line-height: 1.45; color: var(--ink-3); margin-top: 16px; font-family: 'Fraunces', serif; font-style: italic;">
            "Sterke match op Python én finance. Enkel geen teamlead-ervaring, terwijl jullie iemand zoeken die erin groeit: door naar gesprek."
          </div>
        </div>

        <!-- next ranked rows -->
        <div style="padding: 6px 30px;">
          <div style="display: flex; align-items: center; gap: 18px; padding: 16px 0;">
            <div style="width: 40px; height: 40px; border-radius: 999px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">JM</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 22px; font-weight: 600; color: var(--ink); line-height: 1.25;">Jonas Maes</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">5 jaar · Java · banking</div>
            </div>
            <span style="font-size: 21px; font-weight: 700; color: var(--accent); min-width: 48px; text-align: right;">89</span>
            <div style="width: 120px; height: 8px; border-radius: 999px; background: var(--border); overflow: hidden; flex-shrink: 0;"><div style="width: 89%; height: 100%; background: var(--accent);"></div></div>
          </div>
          <div style="display: flex; align-items: center; gap: 18px; padding: 16px 0; border-top: 1px solid var(--border-soft);">
            <div style="width: 40px; height: 40px; border-radius: 999px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">AB</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 22px; font-weight: 600; color: var(--ink); line-height: 1.25;">Aïsha Belkacem</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">6 jaar · Python · data engineering</div>
            </div>
            <span style="font-size: 21px; font-weight: 700; color: var(--accent); min-width: 48px; text-align: right;">86</span>
            <div style="width: 120px; height: 8px; border-radius: 999px; background: var(--border); overflow: hidden; flex-shrink: 0;"><div style="width: 86%; height: 100%; background: var(--accent);"></div></div>
