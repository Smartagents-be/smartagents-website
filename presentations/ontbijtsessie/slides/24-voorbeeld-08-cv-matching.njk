        <!-- footer -->
        <div style="display: flex; align-items: center; gap: 10px; padding: 16px 30px; border-top: 1px solid var(--border-soft); font-size: 19px; color: var(--ink-4);">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          127 andere kandidaten, elk met eigen motivatie
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>24 / 32</div>
    </div>
