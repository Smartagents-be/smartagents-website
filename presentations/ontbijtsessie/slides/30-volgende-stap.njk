<section data-label="30 Volgende stap">
  <div class="slide-frame">
    <div class="eyebrow">Volgende stap</div>
    <h2 class="title" style="margin-top: 28px;">Twee manieren om te starten.</h2>
    <p class="body" style="margin-top: 32px; max-width: 1300px;">
      Eerst inzicht met een SmartScan, of meteen aan de slag op het platform. Jij kiest het tempo.
    </p>

    <div style="margin-top: 64px; display: grid; grid-template-columns: 1fr 1fr; gap: 28px; flex: 1; align-items: stretch;">

      <!-- Path 1 — SmartScan -->
      <div style="--c: #0891b2; background: var(--surface); border: 1px solid color-mix(in srgb, var(--c) 28%, var(--border-soft)); border-radius: 20px; padding: 44px; display: flex; flex-direction: column;">
        <div style="display: flex; align-items: center; gap: 18px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: color-mix(in srgb, var(--c) 12%, transparent); border: 1px solid color-mix(in srgb, var(--c) 30%, transparent); color: var(--c); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <span style="font-size: 22px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4);">Eerst inzicht</span>
        </div>
        <h3 style="font-size: 44px; font-weight: 600; margin-top: 28px; letter-spacing: -0.02em; color: var(--c);">Boek een SmartScan</h3>
        <p style="font-size: 26px; line-height: 1.45; color: var(--ink-3); margin-top: 16px;">
          Eén dag bij jullie. Vast bedrag. Concreet rapport. Geen verkoopgesprek, maar een audit.
        </p>
        <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 16px;">
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Processen en knelpunten in kaart</span></div>
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Geprioriteerde shortlist met ROI per case</span></div>
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Jij beslist daarna, geen verplichting</span></div>
        </div>
      </div>

      <!-- Path 2 — SmartSpace -->
      <div style="--c: var(--accent-smartspace); background: var(--surface); border: 1px solid color-mix(in srgb, var(--c) 28%, var(--border-soft)); border-radius: 20px; padding: 44px; display: flex; flex-direction: column;">
        <div style="display: flex; align-items: center; gap: 18px;">
          <div style="width: 56px; height: 56px; border-radius: 14px; background: color-mix(in srgb, var(--c) 12%, transparent); border: 1px solid color-mix(in srgb, var(--c) 30%, transparent); color: var(--c); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="4" r="1.5"/><circle cx="20" cy="4" r="1.5"/><circle cx="4" cy="20" r="1.5"/><circle cx="20" cy="20" r="1.5"/><line x1="5.4" y1="5.4" x2="9.9" y2="9.9"/><line x1="18.6" y1="5.4" x2="14.1" y2="9.9"/><line x1="5.4" y1="18.6" x2="9.9" y2="14.1"/><line x1="18.6" y1="18.6" x2="14.1" y2="14.1"/></svg>
          </div>
          <span style="font-size: 22px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4);">Meteen starten</span>
        </div>
        <h3 style="font-size: 44px; font-weight: 600; margin-top: 28px; letter-spacing: -0.02em; color: var(--c);">Onboard op SmartSpace</h3>
        <p style="font-size: 26px; line-height: 1.45; color: var(--ink-3); margin-top: 16px;">
          Geen audit nodig? Start vandaag op het platform en bouw van daaruit verder uit.
        </p>
        <div style="margin-top: 32px; display: flex; flex-direction: column; gap: 16px;">
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Werkt zoals ChatGPT, geen leercurve</span></div>
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Basis-apps standaard inbegrepen</span></div>
          <div style="display: flex; align-items: flex-start; gap: 14px; font-size: 24px; line-height: 1.35; color: var(--ink-2);"><span style="width: 9px; height: 9px; margin-top: 11px; border-radius: 50%; background: var(--c); flex-shrink: 0;"></span><span>Uitbreidbaar met apps op maat van je bedrijf</span></div>
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>30 / 32</div>
    </div>
  </div>
</section>
