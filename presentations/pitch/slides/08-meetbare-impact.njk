<!-- ════════════════ 08 · MEETBARE IMPACT ════════════════ -->
  <section data-label="Meetbare impact" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">06</span>Impact &amp; potentieel</p>
      <h1 class="title" style="max-width: 1500px;">Wat <span class="accent">ai oplevert</span><br>voor je organisatie.</h1>

      <div style="display: flex; flex-direction: column; flex: 1; justify-content: space-between; padding-bottom: 72px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 56px; margin-top: 40px; align-items: start;">
          <!-- Industrie-benchmarks -->
          <div>
            <p class="s6-label"><span class="dot"></span>Wat ai vandaag oplevert <span class="muted">— McKinsey 2024–2025</span></p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 18px; align-items: stretch;">
              <div class="stat-block" style="min-height: 238px; justify-content: center;">
                <span class="num">15 – 40 <span style="font-size: 0.55em;">%</span></span>
                <span class="lbl">Minder tijd op kenniswerk-taken in een gen-ai productmanagementstudie</span>
              </div>
              <div class="stat-block" style="min-height: 238px; justify-content: center;">
                <span class="num">57 <span style="font-size: 0.55em;">%</span></span>
                <span class="lbl">Van huidige werkuren heeft technisch automatisatiepotentieel</span>
              </div>
            </div>
          </div>

          <!-- Onze belofte -->
          <div>
            <p class="s6-label"><span class="dot"></span>Onze belofte <span class="muted">— aan elke klant</span></p>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 18px; align-items: stretch;">
              <div class="stat-block" style="min-height: 238px; justify-content: center;">
                <span class="num">24/7</span>
                <span class="lbl">Operationeel, zonder pauzes of downtime</span>
              </div>
              <div class="stat-block" style="min-height: 238px; justify-content: center;">
                <span class="num">&lt; 3 <span style="font-size: 0.55em;">mnd</span></span>
                <span class="lbl">Eerste resultaten zichtbaar</span>
              </div>
            </div>
          </div>
        </div>

        <p class="sec-note" style="font-size: 19px; margin: 0;">Bronnen: McKinsey productmanagementstudie (2024) en MGI "Agents, robots, and us" (2025). Benchmarks, geen garantie; per case te valideren.</p>
      </div>
    </div>
    {% set slideNumber = "08" %}
    {% set slideTotal = "09" %}
    {% include "../../shared/chrome.njk" %}
  </section>
