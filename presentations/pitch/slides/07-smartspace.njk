<!-- ════════════════ 07 · SMARTSPACE ════════════════ -->
  <section data-label="SmartSpace" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <div style="display: flex; align-items: center; gap: 18px; margin-bottom: 28px;">
        <span style="display: inline-flex; align-items: center; justify-content: center; width: 58px; height: 58px; border-radius: 14px; background: rgba(139,92,246,0.10); border: 1px solid rgba(139,92,246,0.30); color: #8b5cf6;">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px;"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="4" r="1.5"/><circle cx="20" cy="4" r="1.5"/><circle cx="4" cy="20" r="1.5"/><circle cx="20" cy="20" r="1.5"/><line x1="5.4" y1="5.4" x2="9.9" y2="9.9"/><line x1="18.6" y1="5.4" x2="14.1" y2="9.9"/><line x1="5.4" y1="18.6" x2="9.9" y2="14.1"/><line x1="18.6" y1="18.6" x2="14.1" y2="14.1"/></svg>
        </span>
        <p class="eyebrow" style="margin: 0; color: #8b5cf6;">SmartSpace · Nieuw product</p>
        <span class="beta-badge" style="background: rgba(139,92,246,0.12); border-color: rgba(139,92,246,0.30); color: #8b5cf6;">Beta</span>
      </div>
      <h1 class="title" style="max-width: 1500px;">Het centrale platform<br>voor jouw <span style="color: #8b5cf6;">KMO</span>.</h1>

      <div style="display: grid; grid-template-columns: 0.78fr 1.22fr; gap: 56px; flex: 1; align-items: center; padding-bottom: 34px;">
        <div>
          <p class="body" style="font-size: 28px; max-width: 720px;">
            Eén <strong style="color: #0f172a;">vertrouwde werkplek</strong> die werkt zoals <strong style="color: #8b5cf6;">ChatGPT</strong>. Je typt gewoon wat je nodig hebt.
          </p>

          <ul style="list-style: none; padding: 0; margin: 36px 0 0; display: flex; flex-direction: column; gap: 22px; max-width: 720px;">
            <li style="display: flex; align-items: flex-start; gap: 16px; font-size: 25px; color: var(--fg); line-height: 1.35;">
              <span style="width: 9px; height: 9px; margin-top: 12px; border-radius: 50%; background: #8b5cf6; flex-shrink: 0;"></span>
              <span>Werkt zoals <strong>ChatGPT</strong>, geen leercurve voor je team.</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 16px; font-size: 25px; color: var(--fg); line-height: 1.35;">
              <span style="width: 9px; height: 9px; margin-top: 12px; border-radius: 50%; background: #8b5cf6; flex-shrink: 0;"></span>
              <span>Komt standaard met de <strong>basis-apps</strong> inbegrepen.</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 16px; font-size: 25px; color: var(--fg); line-height: 1.35;">
              <span style="width: 9px; height: 9px; margin-top: 12px; border-radius: 50%; background: #8b5cf6; flex-shrink: 0;"></span>
              <span>Modulair uit te breiden met <strong>apps op maat</strong> van je bedrijf.</span>
            </li>
            <li style="display: flex; align-items: flex-start; gap: 16px; font-size: 25px; color: var(--fg); line-height: 1.35;">
              <span style="width: 9px; height: 9px; margin-top: 12px; border-radius: 50%; background: #8b5cf6; flex-shrink: 0;"></span>
              <span>Elke klant krijgt zijn <strong>eigen versie</strong> van het platform.</span>
            </li>
          </ul>
        </div>

        <!-- SmartSpace screenshot -->
        <div style="border-radius: 16px; overflow: hidden; background: #fff; box-shadow: 10px 14px 56px rgba(15,23,42,0.15), 3px 5px 20px rgba(15,23,42,0.09), 0 0 0 1px rgba(15,23,42,0.07);">
          <img src="assets/smartspace-ui.png" alt="SmartSpace interface" style="width: 100%; height: auto; display: block;">
        </div>
      </div>
    </div>
    {% set slideNumber = "07" %}
    {% set slideTotal = "09" %}
    {% include "../../shared/chrome.njk" %}
  </section>
