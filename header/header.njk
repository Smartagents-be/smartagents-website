{% set shell = shellConfigs[shellContext] %}
<nav class="navbar" id="navbar">
    <!-- Logo (visible on desktop) -->
    <a href="{{ "/" | locale_url | withPathPrefix }}" class="navbar-logo" aria-label="SmartAgents">
        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
                <linearGradient id="navLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:var(--cyan)"/>
                    <stop offset="50%" style="stop-color:var(--cyan)"/>
                    <stop offset="100%" style="stop-color:var(--blue)"/>
                </linearGradient>
            </defs>
            <g stroke="url(#navLogoGradient)" stroke-width="1.5" fill="none" opacity="0.6">
                <line x1="24" y1="8" x2="12" y2="20"/>
                <line x1="24" y1="8" x2="36" y2="20"/>
                <line x1="12" y1="20" x2="24" y2="24"/>
                <line x1="36" y1="20" x2="24" y2="24"/>
                <line x1="12" y1="20" x2="12" y2="32"/>
                <line x1="36" y1="20" x2="36" y2="32"/>
                <line x1="24" y1="24" x2="24" y2="40"/>
                <line x1="12" y1="32" x2="24" y2="40"/>
                <line x1="36" y1="32" x2="24" y2="40"/>
            </g>
            <g fill="url(#navLogoGradient)">
                <circle cx="24" cy="8" r="4"/>
                <circle cx="12" cy="20" r="3"/>
                <circle cx="36" cy="20" r="3"/>
                <circle cx="24" cy="24" r="3.5"/>
                <circle cx="12" cy="32" r="2.5"/>
                <circle cx="36" cy="32" r="2.5"/>
                <circle cx="24" cy="40" r="3"/>
            </g>
            <circle cx="24" cy="8" r="6" fill="none" stroke="url(#navLogoGradient)" stroke-width="1" opacity="0.4"/>
        </svg>
        <span class="navbar-brand-block">
            <span class="navbar-brand-name">Smart<span class="navbar-brand-accent">Agents</span></span>
            <span class="navbar-tagline">{{ "nav.tagline" | t(locale) }}</span>
        </span>
    </a>

    <!-- Nav links (desktop only) -->
    <div class="navbar-links">
        <div class="navbar-dropdown" data-nav="0">
            <a href="{{ "/" | locale_url | withPathPrefix }}#services" class="navbar-link navbar-dropdown-trigger {% if shell.servicesActive %}active{% endif %}">
                {{ "nav.services" | t(locale) }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
        </div>
        <div class="navbar-dropdown" data-nav="1">
            <a href="{{ "/" | locale_url | withPathPrefix }}#aanpak" class="navbar-link navbar-dropdown-trigger">
                {{ "nav.approach" | t(locale) }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>
        </div>
        <a href="{{ "/" | locale_url | withPathPrefix }}#about" class="navbar-link">{{ "nav.about" | t(locale) }}</a>
        <a href="{{ "/" | locale_url | withPathPrefix }}#contact" class="navbar-link">{{ "nav.contact" | t(locale) }}</a>
        <a href="{{ "/team/" | locale_url | withPathPrefix }}" class="navbar-link {% if shell.teamActive %}active{% endif %}">{{ "nav.team" | t(locale) }}</a>
        <a href="{{ "/jobs/" | locale_url | withPathPrefix }}" class="navbar-link {% if shell.jobsActive %}active{% endif %}">{{ "nav.jobs" | t(locale) }}</a>
    </div>

    <!-- Shared dropdown viewport: single container, panels slide within it -->
    <div class="nav-viewport" aria-hidden="true">
        <div class="nav-panel" data-panel="0">
            <a href="{{ "/services/agentic-ai/" | locale_url | withPathPrefix }}" data-nav-service="agentic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4M8 15h.01M16 15h.01"/></svg>
                {{ "services.agentic.title" | t(locale) }}
            </a>
            <a href="{{ "/services/process-optimization/" | locale_url | withPathPrefix }}" data-nav-service="process">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
                {{ "services.process.title" | t(locale) }}
            </a>
            <a href="{{ "/services/training/" | locale_url | withPathPrefix }}" data-nav-service="training">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                {{ "services.training.title" | t(locale) }}
            </a>
        </div>
        <div class="nav-panel" data-panel="1">
            <a href="{{ "/services/smart-scan/" | locale_url | withPathPrefix }}" data-nav-service="smartscan">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 7V5a2 2 0 0 1 2-2h2M17 3h2a2 2 0 0 1 2 2v2M21 17v2a2 2 0 0 1-2 2h-2M7 21H5a2 2 0 0 1-2-2v-2"/><line x1="7" y1="12" x2="17" y2="12"/></svg>
                {{ "services.smartscan.title" | t(locale) }}
            </a>
            <a href="{{ "/services/ontwerp/" | locale_url | withPathPrefix }}" data-nav-service="ontwerp">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                {{ "services.ontwerp.title" | t(locale) }}
            </a>
            <a href="{{ "/services/ontwikkeling/" | locale_url | withPathPrefix }}" data-nav-service="ontwikkeling">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                {{ "services.ontwikkeling.title" | t(locale) }}
            </a>
            <a href="{{ "/services/implementatie/" | locale_url | withPathPrefix }}" data-nav-service="implementatie">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="16 12 12 8 8 12"/><line x1="12" y1="16" x2="12" y2="8"/></svg>
                {{ "services.implementatie.title" | t(locale) }}
            </a>
            <a href="{{ "/services/optimalisatie-support/" | locale_url | withPathPrefix }}" data-nav-service="optimalisatie">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                {{ "services.optimalisatie.title" | t(locale) }}
            </a>
        </div>
    </div>

    <!-- Right cluster: CTA + lang + MENU scramble -->
    <div class="navbar-right">
        <a href="{{ "/customerzone/" | locale_url | withPathPrefix }}" class="btn btn-nav">{{ "nav.customerzone" | t(locale) }}</a>
        <div class="navbar-lang">
            <a class="lang-btn {% if locale == 'en' %}active{% endif %}" href="{{ enUrl | withPathPrefix }}">EN</a>
            <a class="lang-btn {% if locale == 'nl' %}active{% endif %}" href="{{ nlUrl | withPathPrefix }}">NL</a>
        </div>
        <button class="fullscreen-menu-btn" aria-label="{{ 'nav.menu.open' | t(locale) }}" data-label-close="{{ 'nav.menu.close' | t(locale) }}">
            <span class="menu-label">{{ 'nav.menu.text' | t(locale) }}</span>
            <span class="menu-bars">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>
    </div>
</nav>

<!-- Fixed home pill (non-homepage, mobile only) -->
<a href="{{ "/" | locale_url | withPathPrefix }}" class="home-pill" aria-label="{{ 'nav.home' | t(locale) }}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
    <span class="home-label">{{ 'nav.home.text' | t(locale) }}</span>
</a>

<!-- Fullscreen nav overlay (unchanged) -->
<div class="fullscreen-nav-overlay" aria-hidden="true">
    <nav>
        <a href="{{ "/customerzone/" | locale_url | withPathPrefix }}" class="overlay-nav-cta">{{ "nav.customerzone" | t(locale) }}</a>
        <div class="overlay-nav-group">
            <a href="{{ "/" | locale_url | withPathPrefix }}#aanpak" class="overlay-nav-group-label">{{ "nav.approach" | t(locale) }}</a>
            <div class="overlay-nav-subnav">
                <a href="{{ "/services/smart-scan/" | locale_url | withPathPrefix }}">{{ "services.smartscan.title" | t(locale) }}</a>
                <a href="{{ "/services/ontwerp/" | locale_url | withPathPrefix }}">{{ "services.ontwerp.title" | t(locale) }}</a>
                <a href="{{ "/services/ontwikkeling/" | locale_url | withPathPrefix }}">{{ "services.ontwikkeling.title" | t(locale) }}</a>
                <a href="{{ "/services/implementatie/" | locale_url | withPathPrefix }}">{{ "services.implementatie.title" | t(locale) }}</a>
                <a href="{{ "/services/optimalisatie-support/" | locale_url | withPathPrefix }}">{{ "services.optimalisatie.title" | t(locale) }}</a>
            </div>
        </div>
        <div class="overlay-nav-group">
            <a href="{{ "/" | locale_url | withPathPrefix }}#services" class="overlay-nav-group-label">{{ "nav.services" | t(locale) }}</a>
            <div class="overlay-nav-subnav">
                <a href="{{ "/services/agentic-ai/" | locale_url | withPathPrefix }}">{{ "services.agentic.title" | t(locale) }}</a>
                <a href="{{ "/services/process-optimization/" | locale_url | withPathPrefix }}">{{ "services.process.title" | t(locale) }}</a>
                <a href="{{ "/services/training/" | locale_url | withPathPrefix }}">{{ "services.training.title" | t(locale) }}</a>
            </div>
        </div>
        <a href="{{ "/" | locale_url | withPathPrefix }}#vision-mission">{{ "nav.values" | t(locale) }}</a>
        <a href="{{ "/" | locale_url | withPathPrefix }}#about">{{ "nav.about" | t(locale) }}</a>
        <a href="{{ "/team/" | locale_url | withPathPrefix }}">{{ "nav.team" | t(locale) }}</a>
        <a href="{{ "/" | locale_url | withPathPrefix }}#contact">{{ "nav.contact" | t(locale) }}</a>
        <a href="{{ "/jobs/" | locale_url | withPathPrefix }}">{{ "nav.jobs" | t(locale) }}</a>
    </nav>
</div>

<!-- Lang switcher shown when overlay is open (mobile) -->
<div class="overlay-lang-switcher" aria-hidden="true">
    <a class="lang-btn {% if locale == 'en' %}active{% endif %}" href="{{ enUrl | withPathPrefix }}">EN</a>
    <a class="lang-btn {% if locale == 'nl' %}active{% endif %}" href="{{ nlUrl | withPathPrefix }}">NL</a>
</div>
