<section class="blog-page-hero">
    <div class="container">
        <h1 class="section-title">{{ "blog.hero.title" | t(locale) }}</h1>
        <p class="section-subtitle">{{ "blog.hero.subtitle" | t(locale) }}</p>
    </div>
</section>

<section class="blog-listing">
    <div class="container">
        <div class="blog-filter" role="group" aria-label="{{ 'blog.filter.label' | t(locale) }}">
            <button type="button" class="blog-filter-chip is-active" data-filter-all aria-pressed="true">
                {{ "blog.filter.all" | t(locale) }}
            </button>
            {% for cat in blogCategories %}
                <button type="button" class="blog-filter-chip" data-filter="{{ cat.slug }}" aria-pressed="false">
                    {{ cat[locale] }}
                </button>
            {% endfor %}
        </div>

        <ul class="blog-cards-grid">
            {% for post in collections.blog | byLocale(locale) | reverse %}
                {% set categorySlugs = post.data.categories | join(' ') %}
                <li class="blog-card" data-categories="{{ categorySlugs }}">
                    <a href="{{ post.url | withPathPrefix }}" class="blog-card-link">
                        {% if post.data.image %}
                        <div class="blog-card-thumb">
                            <img src="{{ post.data.image | withPathPrefix }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy" decoding="async"{% if post.data.imagePosition %} style="object-position: {{ post.data.imagePosition }}"{% endif %}>
                        </div>
                        {% endif %}
                        <ul class="blog-card-categories">
                            {% for slug in post.data.categories %}
                                {% for cat in blogCategories %}
                                    {% if cat.slug == slug %}
                                        <li class="blog-cat blog-cat--{{ cat.slug }}">{{ cat[locale] }}</li>
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                        </ul>
                        <h2 class="blog-card-title">{{ post.data.title }}</h2>
                        <p class="blog-card-date">{{ post.data.date | localeDate(locale) }}</p>
                        <p class="blog-card-excerpt">{{ post.data.excerpt }}</p>
                        <span class="blog-card-read-more">
                            {{ "blog.read.more" | t(locale) }}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <line x1="5" y1="12" x2="19" y2="12"/>
                                <polyline points="12 5 19 12 12 19"/>
                            </svg>
                        </span>
                    </a>
                </li>
            {% endfor %}
        </ul>
    </div>
</section>
