---
permalink: /secured/index.html
excludeFromSitemap: true
---
<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex">
  <title>SmartAgents — Documenten</title>
  <link rel="stylesheet" href="/assets/css/base.css?v={{ assetsVersion }}">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      background: var(--dark);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: var(--white);
      padding: 3rem 1.5rem;
    }
    header {
      max-width: 680px;
      margin: 0 auto 2.5rem;
    }
    .brand {
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.3rem;
    }
    .subtitle {
      font-size: 0.9rem;
      color: var(--gray);
    }
    .list {
      max-width: 680px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .item {
      background: var(--dark-lighter);
      border: 1px solid var(--white-10);
      border-radius: 10px;
      padding: 1.1rem 1.25rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }
    .item-name {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--white);
    }
    .actions {
      display: flex;
      gap: 0.5rem;
      flex-shrink: 0;
    }
    .btn {
      padding: 0.4rem 0.9rem;
      border-radius: 6px;
      font-size: 0.82rem;
      font-weight: 600;
      text-decoration: none;
      transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.8; }
    .btn-view {
      background: var(--cyan);
      color: var(--dark);
    }
    .btn-pdf {
      background: transparent;
      border: 1px solid var(--white-10);
      color: var(--gray-light);
    }
    .empty {
      max-width: 680px;
      margin: 0 auto;
      color: var(--gray);
      font-size: 0.9rem;
    }
    .brand-base { color: var(--white); }
    .brand-accent { color: var(--cyan); }
  </style>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18080961249"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18080961249');
    </script>
</head>
<body>
  <header>
    <div class="brand"><span class="brand-base">Smart</span><span class="brand-accent">Agents</span></div>
    <div class="subtitle">Beveiligde documenten</div>
  </header>

  {% if securedFiles.length %}
  <div class="list">
    {% for doc in securedFiles %}
    <div class="item">
      <span class="item-name">{{ doc.name }}</span>
      <div class="actions">
        {% if doc.html %}<a class="btn btn-view" href="{{ doc.html }}">Bekijken</a>{% endif %}
        {% if doc.pdf %}<a class="btn btn-pdf" href="{{ doc.pdf }}" download>PDF</a>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p class="empty">Geen documenten beschikbaar.</p>
  {% endif %}
</body>
</html>
