# Pitch-decks staan achter de secured-login onder /secured/presentations/.
# De oude korte link en de vorige publieke /presentations/-paden zijn al
# gedeeld. Browsers behouden het #slide-fragment bij een redirect, dus
# /pitch/#1 komt netjes uit op de beveiligde deck-URL met hetzelfde fragment.
/pitch /secured/presentations/pitch/ 301
/pitch/* /secured/presentations/pitch/:splat 301

# Oude publieke deck-URLs doorsturen naar de beveiligde locatie.
/presentations/* /secured/presentations/:splat 301

# De c-level trainingspagina heet nu management.
/services/training/c-level/ /services/training/management/ 301
/en/services/training/c-level/ /en/services/training/management/ 301
