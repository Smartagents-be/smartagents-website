<header>
  <div class="brand"><span class="brand-base">Smart</span><span class="brand-accent">Agents</span></div>
  <div class="subtitle">Beveiligde documenten</div>
</header>

{% if securedFiles.length %}
<h2 class="section-title">Documenten</h2>
<div class="list">
  {% for doc in securedFiles %}
  <div class="item">
    <span class="item-name">{{ doc.name }}</span>
    <div class="actions">
      {% if doc.html %}<a class="btn btn-view" href="{{ doc.html | withPathPrefix }}">Bekijken</a>{% endif %}
      {% if doc.pdf %}<a class="btn btn-pdf" href="{{ doc.pdf | withPathPrefix }}" download>PDF</a>{% endif %}
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if pitchDecks.length %}
<h2 class="section-title">Pitches</h2>
<div class="list">
  {% for deck in pitchDecks %}
  <div class="item">
    <span class="item-name">{{ deck.name }}</span>
    <div class="actions">
      <a class="btn btn-view" href="{{ deck.html | withPathPrefix }}">Bekijken</a>
    </div>
  </div>
  {% endfor %}
</div>
{% endif %}

{% if not securedFiles.length and not pitchDecks.length %}
<p class="empty">Geen documenten beschikbaar.</p>
{% endif %}
