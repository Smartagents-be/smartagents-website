<!doctype html>
<html lang="nl">
<head>
<meta charset="utf-8">
<title>SmartAgents — Sales 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/secured/tokens.css">
<style>
  deck-stage:not(:defined) { visibility: hidden; }
  html, body { margin: 0; padding: 0; background: #000; }
  body { font-family: var(--font-sans); color: var(--fg); }

  :root {
    --pad-x: 120px;
    --pad-y: 100px;
    --pad-y-bottom: 88px;
  }

  /* ── Slide foundations ───────────────────────────────────────── */
  .slide {
    background: var(--sa-dark);
    color: var(--fg);
    font-family: var(--font-sans);
    overflow: hidden;
    position: relative;
  }
  .slide.deeper { background: var(--sa-dark-deep); }

  .frame {
    position: absolute;
    inset: 0;
    padding: var(--pad-y) var(--pad-x) var(--pad-y-bottom);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
  }

  /* Glow */
  .glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 1100px 700px at 18% 110%, var(--sa-cyan-15) 0%, transparent 55%),
      radial-gradient(ellipse 1200px 800px at 92% -10%, rgba(79,108,247,0.18) 0%, transparent 55%);
    z-index: 0;
  }
  .glow.center { background: radial-gradient(ellipse 1400px 900px at 50% 50%, var(--sa-cyan-15) 0%, transparent 60%); }
  .glow.soft   { background: radial-gradient(ellipse 900px 600px at 80% 100%, var(--sa-cyan-08) 0%, transparent 60%); }
  .frame > * { position: relative; z-index: 1; }

  /* Chrome */
  .chrome {
    position: absolute;
    left: var(--pad-x);
    right: var(--pad-x);
    bottom: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 24px;
    color: var(--fg-muted);
    z-index: 2;
    letter-spacing: 0.02em;
  }
  .chrome .brand { display: inline-flex; align-items: center; gap: 14px; color: var(--fg); font-weight: 600; }
  .chrome .brand img { width: 32px; height: 32px; }
  .chrome .pageno { font-variant-numeric: tabular-nums; color: var(--fg-subtle); }

  /* Type primitives */
  .eyebrow {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sa-cyan);
    margin: 0 0 28px;
  }
  .eyebrow .num { color: var(--fg-muted); margin-right: 14px; font-weight: 600; }
  h1.title {
    font-size: 84px;
    line-height: 1.04;
    letter-spacing: -0.025em;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 28px;
    max-width: 1500px;
    text-wrap: balance;
  }
  h2.h2 {
    font-size: 64px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 28px;
    text-wrap: balance;
  }
  .lede {
    font-size: 32px;
    line-height: 1.35;
    font-weight: 400;
    color: var(--fg-muted);
    max-width: 1400px;
    margin: 0;
    text-wrap: pretty;
  }
  .body {
    font-size: 28px;
    line-height: 1.5;
    color: var(--fg-muted);
    max-width: 1300px;
    text-wrap: pretty;
  }
  .accent { color: var(--sa-cyan); }
  .gradient-text {
    background: linear-gradient(135deg, #00d8ff 0%, #22d3ee 45%, #4f6cf7 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* ── Light theme (white slides) ── */
  .slide.light {
    --fg: #0f172a;
    --fg-muted: #475569;
    --fg-subtle: #64748b;
    --sa-light: #0f172a;
    --sa-white-05: rgba(15,23,42,0.04);
    --sa-white-07: rgba(15,23,42,0.06);
    --sa-white-10: rgba(15,23,42,0.10);
    --sa-white-25: rgba(15,23,42,0.20);
    --sa-cyan: #0891b2;
    --sa-cyan-08: rgba(8,145,178,0.06);
    --sa-cyan-15: rgba(8,145,178,0.10);
    --sa-cyan-20: rgba(8,145,178,0.16);
    --sa-cyan-30: rgba(8,145,178,0.26);
    --sa-cyan-40: rgba(8,145,178,0.42);
    --sa-cyan-60: rgba(8,145,178,0.60);
    --sa-dark: #ffffff;
    --sa-dark-deep: #f1f5f9;
    --sa-dark-lighter: #f8fafc;
    background: #ffffff !important;
    color: #0f172a;
  }
  .slide.light .glow { opacity: 0.55; mix-blend-mode: multiply; }
  .slide.light .gradient-text {
    background: linear-gradient(135deg, #0891b2 0%, #0e7490 45%, #4f46e5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Card */
  .card {
    background: var(--sa-white-05);
    border: 1px solid var(--sa-white-10);
    border-radius: 20px;
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .card .lab {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sa-cyan);
  }
  .card h3 {
    font-size: 36px;
    line-height: 1.12;
    margin: 0;
    color: var(--fg);
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .card p {
    font-size: 24px;
    line-height: 1.5;
    color: var(--fg-muted);
    margin: 0;
  }
  .card ul {
    list-style: none;
    padding: 0;
    margin: 4px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .card li {
    font-size: 24px;
    color: var(--fg);
    display: flex;
    align-items: center;
    gap: 12px;
    line-height: 1.35;
  }
  .card li::before {
    content: '';
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--sa-cyan);
    flex-shrink: 0;
  }
  .card .num-lg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px; height: 60px;
    border-radius: 14px;
    background: var(--sa-cyan-15);
    border: 1px solid var(--sa-cyan-30);
    color: var(--sa-cyan);
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 6px;
  }

  /* Grids */
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .grid-3-2 { display: grid; grid-template-columns: repeat(3, 1fr); grid-template-rows: 1fr 1fr; gap: 20px; }

  /* Cover */
  .cover {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  .cover-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 24px;
    color: var(--fg-muted);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .cover-meta .cyan-bar {
    display: inline-flex;
    align-items: center;
    gap: 18px;
    color: var(--sa-cyan);
    letter-spacing: 0.32em;
  }
  .cover-meta .cyan-bar .bar { width: 56px; height: 1px; background: var(--sa-cyan-40); }
  .cover-logo {
    width: 84px; height: 84px;
    filter: drop-shadow(0 0 28px var(--sa-cyan-40));
  }
  .cover h1 {
    font-size: 124px;
    line-height: 0.96;
    letter-spacing: -0.035em;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
  }
  .cover .sub {
    font-size: 36px;
    line-height: 1.35;
    margin-top: 32px;
    color: var(--fg-muted);
    max-width: 1300px;
    font-weight: 400;
  }
  .cover .tagline {
    font-size: 28px;
    color: var(--sa-cyan);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* Steps row (slide 4) */
  .steps {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .step {
    border: 1px solid var(--sa-white-10);
    border-radius: 18px;
    padding: 28px 24px;
    background: var(--sa-white-05);
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 320px;
    position: relative;
  }
  .step .n {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--sa-cyan);
  }
  .step .big-n {
    font-size: 60px;
    line-height: 0.9;
    font-weight: 700;
    color: var(--sa-cyan);
    letter-spacing: -0.02em;
    margin-bottom: 2px;
  }
  .step h4 {
    font-size: 32px;
    line-height: 1.1;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .step p {
    font-size: 24px;
    line-height: 1.45;
    color: var(--fg-muted);
    margin: 0;
  }

  /* Section row connector */
  .steps-row { position: relative; }
  .steps-row::before {
    content: '';
    position: absolute;
    top: 56px; left: 28px; right: 28px;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--sa-cyan-30) 10%, var(--sa-cyan-30) 90%, transparent 100%);
    z-index: 0;
  }

  /* Sector item */
  .sector {
    background: var(--sa-white-05);
    border: 1px solid var(--sa-white-10);
    border-radius: 16px;
    padding: 26px 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .sector h4 {
    font-size: 28px;
    margin: 0 0 4px;
    color: var(--fg);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .sector ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sector li {
    font-size: 24px;
    color: var(--fg-muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sector li::before {
    content: '';
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--sa-cyan);
    flex-shrink: 0;
  }

  /* Stat */
  .stat {
    font-size: 132px;
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--sa-cyan);
    font-feature-settings: "tnum" 1;
  }
  .stat-block {
    border-radius: 18px;
    padding: 32px 28px;
    background: var(--sa-white-05);
    border: 1px solid var(--sa-white-10);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .stat-block .num {
    font-size: 80px;
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.035em;
    color: var(--sa-cyan);
  }
  .stat-block .lbl {
    font-size: 24px;
    line-height: 1.4;
    color: var(--fg-muted);
    margin-top: 4px;
  }

  /* Chart card */
  .chart-card {
    background: #0f172a;
    border-radius: 18px;
    padding: 32px 36px;
    border: 1px solid rgba(15,23,42,0.10);
    overflow: hidden;
  }

  /* Founders */
  .founder {
    display: grid;
    grid-template-columns: 200px 1fr;
    background: #f8fafc;
    border: 1px solid rgba(15,23,42,0.08);
    border-radius: 20px;
    overflow: hidden;
    min-height: 240px;
  }
  .founder .photo {
    background-size: cover;
    background-position: center 20%;
    background-repeat: no-repeat;
  }
  .founder .info {
    padding: 30px 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: center;
  }
  .founder .info .role {
    font-size: 24px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #0891b2;
    font-weight: 700;
  }
  .founder .info h3 {
    font-size: 36px;
    font-weight: 600;
    color: #0f172a;
    margin: 0;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }
  .founder .info p {
    font-size: 24px;
    color: #475569;
    margin: 0;
    line-height: 1.45;
  }

  /* SmartSpace module pill */
  .mod {
    background: var(--sa-white-05);
    border: 1px solid var(--sa-cyan-30);
    border-radius: 14px;
    padding: 22px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--fg);
    font-size: 26px;
    font-weight: 500;
  }
  .mod .icon {
    width: 12px; height: 12px;
    border-radius: 50%;
    background: var(--sa-cyan);
    flex-shrink: 0;
    box-shadow: 0 0 16px var(--sa-cyan-40);
  }
  .beta-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    border-radius: 999px;
    background: var(--sa-cyan-15);
    border: 1px solid var(--sa-cyan-30);
    color: var(--sa-cyan);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Closing */
  .closing-h1 {
    font-size: 112px;
    line-height: 1;
    letter-spacing: -0.03em;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
    text-wrap: balance;
    max-width: 1600px;
  }
</style>
</head>
<body>

<deck-stage width="1920" height="1080">

  <!-- ════════════════ 01 · COVER ════════════════ -->
  <section data-label="Cover" class="slide deeper">
    <div class="glow"></div>
    <div class="frame cover">
      <div class="cover-meta">
        <span class="cyan-bar"><span class="bar"></span>SmartAgents · Sales 2026</span>
        <img src="/assets/logo.svg" alt="SmartAgents" class="cover-logo">
      </div>

      <div>
        <h1>Transformeer uw bedrijf<br>met <span class="gradient-text">intelligente automatisatie.</span></h1>
        <p class="sub">Slimmere workflows. Lagere kosten. Meetbaar resultaat.</p>
      </div>

      <div class="cover-meta">
        <span class="tagline">Digitale collega's die nooit slapen.</span>
        <span>smartagents.be</span>
      </div>
    </div>
  </section>

  <!-- ════════════════ 02 · WIE ZIJN WIJ ════════════════ -->
  <section data-label="Wie zijn wij" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">01</span>Wie zijn wij?</p>
      <h1 class="title" style="max-width: 1400px;">Onze visie, missie<br>en waarden.</h1>

      <div class="grid-3" style="margin-top: 48px;">
        <div class="card">
          <span class="lab">Visie</span>
          <h3>Intelligente digitale collega's voor elk bedrijf.</h3>
          <p>AI die mensen niet vervangt — maar versterkt, zodat teams zich kunnen richten op wat écht telt.</p>
        </div>
        <div class="card">
          <span class="lab">Missie</span>
          <h3>Meetbaar resultaat vanaf dag één.</h3>
          <p>Autonome AI-agents en automatisatie. Geen hype, geen zwarte dozen — gewoon intelligente systemen die werken naast uw team.</p>
        </div>
        <div class="card">
          <span class="lab">Waarden</span>
          <h3>Transparantie, vertrouwen en echte impact.</h3>
          <p>Eerlijke communicatie, meetbaar resultaat en langdurige partnerschappen. Technologie die echt het verschil maakt.</p>
        </div>
      </div>
    </div>
    <div class="chrome">
      <span class="brand"><img src="/assets/logo.svg" alt="">SmartAgents</span>
      <span class="pageno">02 / 10</span>
    </div>
  </section>

  <!-- ════════════════ 03 · KERNSERVICES ════════════════ -->
  <section data-label="Kernservices" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Onze drie kernservices</p>
      <h1 class="title" style="max-width: 1600px;">Van analyse en training tot<br>volledige <span class="accent">AI-automatisatie</span>.</h1>

      <div class="grid-3" style="margin-top: 48px;">
        <div class="card">
          <div class="num-lg">01</div>
          <h3>Agentic Automatisatie</h3>
          <p style="font-size: 24px;">AI-agents die redeneren, plannen en uitvoeren.</p>
          <ul>
            <li>Multi-agent systemen</li>
            <li>Tool-gebruik &amp; integraties</li>
            <li>Autonoom redeneren</li>
            <li>Mens-in-de-loop controle</li>
          </ul>
        </div>
        <div class="card">
          <div class="num-lg">02</div>
          <h3>Procesoptimalisatie</h3>
          <p style="font-size: 24px;">Van analyse tot scherpere workflows.</p>
          <ul>
            <li>Gedetailleerde procesanalyse</li>
            <li>Knelpunten &amp; verspilling elimineren</li>
            <li>Workflow herontwerp</li>
            <li>KPI-gedreven aanpak</li>
          </ul>
        </div>
        <div class="card">
          <div class="num-lg">03</div>
          <h3>Training &amp; Workshops</h3>
          <p style="font-size: 24px;">Uw mensen klaarstomen voor de AI-era.</p>
          <ul>
            <li>Op maat voor elk niveau</li>
            <li>Praktische AI-vaardigheden</li>
            <li>Verhoogd vertrouwen &amp; adoptie</li>
            <li>Change-management begeleiding</li>
          </ul>
        </div>
      </div>
    </div>
    <div class="chrome">
      <span class="brand"><img src="/assets/logo.svg" alt="">SmartAgents</span>
      <span class="pageno">03 / 10</span>
    </div>
  </section>

  <!-- ════════════════ 04 · PLAN VAN AANPAK ════════════════ -->
  <section data-label="Plan van aanpak" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">03</span>Ons plan van aanpak</p>
      <h1 class="title" style="max-width: 1500px;">Van idee tot resultaat<br>in <span class="accent">5 concrete stappen</span>.</h1>

      <div class="steps steps-row" style="margin-top: 60px;">
        <div class="step">
          <span class="big-n">01</span>
          <h4>Smart Scan</h4>
          <p>Processen en knelpunten in kaart brengen — waar kan AI het verschil maken?</p>
        </div>
        <div class="step">
          <span class="big-n">02</span>
          <h4>Ontwerp</h4>
          <p>Oplossing op maat: workflows, agents en integraties met de meeste impact.</p>
        </div>
        <div class="step">
          <span class="big-n">03</span>
          <h4>Ontwikkeling</h4>
          <p>Stap voor stap bouwen en testen — u volgt mee en geeft feedback.</p>
        </div>
        <div class="step">
          <span class="big-n">04</span>
          <h4>Implementatie</h4>
          <p>Naadloze uitrol in uw omgeving, aansluiting op bestaande systemen.</p>
        </div>
        <div class="step">
          <span class="big-n">05</span>
          <h4>Optimalisatie</h4>
          <p>Blijven bijsturen en uitbreiden zodat processen slimmer worden.</p>
        </div>
      </div>
    </div>
    <div class="chrome">
      <span class="brand"><img src="/assets/logo.svg" alt="">SmartAgents</span>
      <span class="pageno">04 / 10</span>
    </div>
  </section>

  <!-- ════════════════ 05 · WAAROM SMARTAGENTS ════════════════ -->
  <section data-label="Waarom SmartAgents" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">04</span>Waarom SmartAgents?</p>
      <h1 class="title" style="max-width: 1500px;">Wat ons onderscheidt<br>van de rest.</h1>

      <div class="grid-2" style="margin-top: 48px;">
        <div class="card">
          <span class="lab">01 · Expertise</span>
          <h3>Toonaangevende expertise</h3>
          <p style="font-size: 24px;">Diepgaande kennis van AI-agents en procesautomatisatie, gebundeld in één hands-on team.</p>
        </div>
        <div class="card">
          <span class="lab">02 · Resultaat</span>
          <h3>Bewezen resultaat</h3>
          <p style="font-size: 24px;">Meetbare KPI's, transparante rapportage en aantoonbare kostenbesparing in meerdere sectoren.</p>
        </div>
        <div class="card">
          <span class="lab">03 · Begeleiding</span>
          <h3>End-to-end begeleiding</h3>
          <p style="font-size: 24px;">Van Smart Scan tot support. Wij begeleiden het volledige traject — u hoeft niets zelf te coördineren.</p>
        </div>
        <div class="card">
          <span class="lab">04 · Schaalbaar</span>
          <h3>Schaalbaar &amp; toekomstvast</h3>
          <p style="font-size: 24px;">Systemen die meegroeien met uw bedrijf. Vandaag één agent, morgen een volledig AI-ecosysteem.</p>
        </div>
      </div>
    </div>
    <div class="chrome">
      <span class="brand"><img src="/assets/logo.svg" alt="">SmartAgents</span>
      <span class="pageno">05 / 10</span>
    </div>
  </section>

  <!-- ════════════════ 06 · SECTOREN ════════════════ -->
  <section data-label="Sectoren" class="slide light">
