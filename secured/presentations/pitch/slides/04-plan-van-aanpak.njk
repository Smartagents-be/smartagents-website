<!-- ════════════════ 04 · PLAN VAN AANPAK ════════════════ -->
  <section data-label="Plan van aanpak" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">03</span>Ons plan van aanpak</p>
      <h1 class="title" style="max-width: 1500px;">Van idee tot resultaat<br>in <span class="accent">5 concrete stappen</span>.</h1>

      <div class="frame-body">
      <div class="steps steps-row" style="margin-top: 60px;">
        <div class="step" style="--c:#4f6cf7">
          <div class="step-head">
            <span class="step-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/></svg></span>
            <span class="big-n">01</span>
          </div>
          <h4>SmartScan</h4>
          <p><strong>Processen en knelpunten</strong> in kaart brengen, waar kan ai het verschil maken?</p>
        </div>
        <div class="step" style="--c:#f43f5e">
          <div class="step-head">
            <span class="step-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h6"/><path d="M14.5 4.5a2.12 2.12 0 1 1 3 3L8 17l-4 1 1-4 9.5-9.5z"/></svg></span>
            <span class="big-n">02</span>
          </div>
          <h4>Ontwerp</h4>
          <p>Oplossing op maat: workflows, agents en integraties met de <strong>meeste impact</strong>.</p>
        </div>
        <div class="step" style="--c:#10b981">
          <div class="step-head">
            <span class="step-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="10" y1="20" x2="14" y2="4"/></svg></span>
            <span class="big-n">03</span>
          </div>
          <h4>Ontwikkeling</h4>
          <p><strong>Stap voor stap</strong> bouwen en testen, je volgt mee en geeft feedback.</p>
        </div>
        <div class="step" style="--c:#f59e0b">
          <div class="step-head">
            <span class="step-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg></span>
            <span class="big-n">04</span>
          </div>
          <h4>Implementatie</h4>
          <p><strong>Naadloze uitrol</strong>, met aansluiting op je bestaande systemen.</p>
        </div>
        <div class="step" style="--c:#6366f1">
          <div class="step-head">
            <span class="step-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="20" x2="6" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="18" y1="20" x2="18" y2="14"/></svg></span>
            <span class="big-n">05</span>
          </div>
          <h4>Optimalisatie</h4>
          <p>Blijven <strong>bijsturen en uitbreiden</strong> zodat processen slimmer worden.</p>
        </div>
      </div>

      <div class="aanpak-choice">
        <span class="ac-lead">Al tijdens de <strong>SmartScan</strong> kies je je fundament:</span>
        <span class="ac-opt">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          <span><strong>Maatwerk</strong> in je eigen omgeving</span>
        </span>
        <span class="ac-or">of</span>
        <span class="ac-opt ac-opt--ss">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="4" r="1.5"/><circle cx="20" cy="4" r="1.5"/><circle cx="4" cy="20" r="1.5"/><circle cx="20" cy="20" r="1.5"/><line x1="5.4" y1="5.4" x2="9.9" y2="9.9"/><line x1="18.6" y1="5.4" x2="14.1" y2="9.9"/><line x1="5.4" y1="18.6" x2="9.9" y2="14.1"/><line x1="18.6" y1="18.6" x2="14.1" y2="14.1"/></svg>
          <span><strong>SmartSpace</strong>, ons eigen platform</span>
        </span>
      </div>
      </div>
    </div>
    {% set slideNumber = "04" %}
    {% set slideTotal = "09" %}
    {% include "../../shared/chrome.njk" %}
  </section>
