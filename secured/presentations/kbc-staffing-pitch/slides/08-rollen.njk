          </div>
        </div>

        <div class="t-stem">
          <span class="t-stem-label">Diepe kernspecialisatie</span>
          <span class="pill">Full-stack</span>
          <span class="pill">Backend</span>
          <span class="pill">Frontend</span>
          <span class="pill">Data / ML</span>
          <span class="pill">Platform / DevOps</span>
        </div>
      </div>
    </div>
    {% set slideNumber = "08" %}
    {% set slideTotal = "13" %}
    {% include "../../shared/chrome.njk" %}
