<!-- ════════════════ 03 · WIE ZIJN WIJ ════════════════ -->
  <section data-label="Wie zijn wij" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Wie zijn wij?</p>
      <h2 class="h2" style="max-width: 1400px;">Onze geloofwaardigheid komt uit <span class="accent">zelf bouwen</span>.</h2>

      <div class="frame-body">
        <div class="grid-3" style="margin-top: 44px; align-content: start;">
          <div class="card">
            <span class="lab">Praktijk</span>
            <h3>Agents in echte processen</h3>
            <p>Voor KMO's realiseren we AI-oplossingen in sales, finance, operations, support en administratie.</p>
          </div>
          <div class="card">
            <span class="lab">Platform</span>
            <h3>SmartSpace als productbewijs</h3>
            <p>Ons platform bundelt agents, kennis, workflows en controle. Dat dwingt ons om voorbij demo's te denken.</p>
          </div>
          <div class="card">
            <span class="lab">Mensen</span>
            <h3>Delivery als kwaliteitslat</h3>
            <p>We beoordelen mensen op code, architectuur, evaluatie, integraties en productiegedrag.</p>
          </div>
        </div>
      </div>
    </div>
    {% set slideNumber = "03" %}
    {% set slideTotal = "13" %}
    {% include "../../shared/chrome.njk" %}
