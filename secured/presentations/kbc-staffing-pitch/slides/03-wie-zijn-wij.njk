<!-- ════════════════ 03 · WIE ZIJN WIJ ════════════════ -->
  <section data-label="Wie zijn wij" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Wie zijn wij?</p>
      <h2 class="h2" style="max-width: 1400px;">Onze geloofwaardigheid komt uit <span class="accent">zelf bouwen</span>.</h2>

      <div class="frame-body">
        <div class="grid-3" style="align-content: start;">
          <div class="card">
            <span class="lab">Praktijk</span>
            <h3>Agents in echte processen</h3>
            <p>Voor KMO's realiseren we AI-oplossingen in sales, finance, operations, support en administratie. Daarnaast geven we trainings en bieden we aftercare, als vaste AI-partner van de KMO.</p>
          </div>
          <div class="card">
            <span class="lab">Platform</span>
            <div class="icon-title">
              <span class="card-ico" style="--c: var(--accent-smartspace);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><circle cx="4" cy="4" r="1.5"/><circle cx="20" cy="4" r="1.5"/><circle cx="4" cy="20" r="1.5"/><circle cx="20" cy="20" r="1.5"/><line x1="5.4" y1="5.4" x2="9.9" y2="9.9"/><line x1="18.6" y1="5.4" x2="14.1" y2="9.9"/><line x1="5.4" y1="18.6" x2="9.9" y2="14.1"/><line x1="18.6" y1="18.6" x2="14.1" y2="14.1"/></svg></span>
              <h3>SmartSpace als productbewijs</h3>
            </div>
            <p>Ons platform bundelt agents, kennis, workflows en controle. Dat dwingt ons om voorbij demo's te denken.</p>
          </div>
          <div class="card">
            <span class="lab">Mensen</span>
            <h3>Delivery als kwaliteitsniveau</h3>
            <p>We beoordelen mensen op code, architectuur, evaluatie, integraties en productiegedrag.</p>
          </div>
        </div>
      </div>
    </div>
    {% set slideNumber = "03" %}
    {% set slideTotal = "13" %}
    {% include "../../shared/chrome.njk" %}
  </section>
