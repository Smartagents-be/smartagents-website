<!-- ════════════════ 03 · WIE ZIJN WIJ ════════════════ -->
  <section data-label="Wie zijn wij" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Wie zijn wij?</p>
      <h2 class="h2" style="max-width: 1400px;">Onze visie, missie <span class="accent">en waarden</span>.</h2>

      <div class="grid-3" style="margin-top: 44px; align-content: start;">
        <div class="card">
          <span class="lab">Visie</span>
          <h3>Intelligente digitale collega's voor elk bedrijf.</h3>
          <p>AI die mensen niet vervangt, maar versterkt. Teams kunnen zich richten op wat écht telt.</p>
        </div>
        <div class="card">
          <span class="lab">Missie</span>
          <h3>Meetbaar resultaat vanaf dag één.</h3>
          <p>Autonome AI-agents en automatisatie. Geen hype, geen zwarte dozen: intelligente systemen die werken naast uw team, onder uw controle.</p>
        </div>
        <div class="card">
          <span class="lab">Waarden</span>
          <h3>Transparantie, vertrouwen en echte impact.</h3>
          <p>Eerlijke communicatie, meetbaar resultaat en langdurige partnerschappen. Technologie die echt het verschil maakt.</p>
        </div>
      </div>
    </div>
    {% set slideNumber = "03" %}
    {% set slideTotal = "16" %}
    {% include "../../shared/chrome.njk" %}
  </section>
