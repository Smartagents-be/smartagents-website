<!-- ════════════════ 05 · TIJD, GELD & ORGANISATIE ════════════════ -->
  <section data-label="Tijd &amp; organisatie" class="slide light cat-themed" style="--c: #0d9488;">
    <div class="glow soft"></div>
    <div class="frame">
      <div class="cat-head">
        <span class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </span>
        <div class="cat-text">
          <p class="eyebrow"><span class="num">05</span>Tijd, geld &amp; organisatie · proces + AI</p>
          <h2 class="h2">Minder lekkage, <span class="accent">vlottere organisatie</span>.</h2>
        </div>
      </div>

      <div class="frame-body">
      <div class="grid-4" style="margin-top: 40px; align-content: start;">
        <div class="card">
          <span class="num-lg">05</span>
          <h3>Factuuropmaak &amp; nazicht</h3>
          <p>Van gelogde uren en dossierkosten naar een factuurklaar voorstel, klaar voor nazicht.</p>
        </div>
        <div class="card">
          <span class="num-lg">06</span>
          <h3>Debiteurenbeheer</h3>
          <p>Gestructureerde opvolging, openstaande facturen sneller geïnd.</p>
        </div>
        <div class="card">
          <span class="num-lg">07</span>
          <h3>Modeldocumenten &amp; templates</h3>
          <p>Eén beheerde bibliotheek in plaats van ieders eigen versie.</p>
        </div>
        <div class="card">
          <span class="num-lg">08</span>
          <h3>Onboarding &amp; capaciteit</h3>
          <p>Snellere inwerking en beter zicht op de werkverdeling.</p>
        </div>
      </div>

      <div class="callout">
        Minder omzetlekkage en een <strong>vlottere, beter georganiseerde praktijk</strong>.
      </div>
      </div>
    </div>
    {% set slideNumber = "05" %}
    {% set slideTotal = "11" %}
    {% include "../../shared/chrome.njk" %}
  </section>
