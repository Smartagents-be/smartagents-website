<!-- ════════════════ 10 · WAAR BEGINNEN WE ════════════════ -->
  <section data-label="Waar beginnen we" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">10</span>Waar beginnen we</p>
      <h2 class="h2">Drie quick wins met <span class="accent">snelle terugverdientijd</span>.</h2>

      <div class="grid-3" style="margin-top: 40px; align-content: start;">
        <div class="card">
          <span class="num-lg">01</span>
          <h3>Documentopstelling</h3>
          <p>Eerste drafts uit eigen modellen, met directe tijdwinst op repetitief werk.</p>
        </div>
        <div class="card">
          <span class="num-lg">02</span>
          <h3>Dossiersamenvatting</h3>
          <p>Lange dossiers in seconden samengevat bij overname of zitting.</p>
        </div>
        <div class="card">
          <span class="num-lg">03</span>
          <h3>Interne kennis-assistent</h3>
          <p>Eigen knowhow doorzoekbaar, minder dubbel werk en snellere antwoorden.</p>
        </div>
      </div>

      <div class="callout">
        Snel bewijzen in het klein, daarna gericht <strong>opschalen via de SmartScan</strong>.
      </div>
    </div>
    {% set slideNumber = "10" %}
    {% set slideTotal = "11" %}
    {% include "../../shared/chrome.njk" %}
  </section>
