<!-- ════════════════ 04 · DOSSIER & RISICO ════════════════ -->
  <section data-label="Dossier &amp; risico" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">04</span>Dossier &amp; risico · proces</p>
      <h2 class="h2">Grip op dossiers <span class="accent">en deadlines</span>.</h2>

      <div class="grid-4" style="margin-top: 40px; align-content: start;">
        <div class="card">
          <span class="num-lg">01</span>
          <h3>Termijnbewaking</h3>
          <p>Centrale bewaking van verjarings- en proceduretermijnen.</p>
        </div>
        <div class="card">
          <span class="num-lg">02</span>
          <h3>Intake &amp; conflictcheck</h3>
          <p>Gestandaardiseerde intake met automatische conflictcontrole.</p>
        </div>
        <div class="card">
          <span class="num-lg">03</span>
          <h3>Dossier- &amp; matterbeheer</h3>
          <p>Eén overzicht van fase, eigenaar en volgende actie.</p>
        </div>
        <div class="card">
          <span class="num-lg">04</span>
          <h3>Documentbeheer (DMS)</h3>
          <p>Versiebeheer en naamgeving, met één bron van waarheid.</p>
        </div>
      </div>

      <div class="callout">
        Minder aansprakelijkheidsrisico en <strong>altijd grip</strong> op waar een dossier staat.
      </div>
    </div>
    {% set slideNumber = "04" %}
    {% set slideTotal = "11" %}
    {% include "../../shared/chrome.njk" %}
  </section>
