<!-- ════════════════ 02 · ONZE AANPAK ════════════════ -->
  <section data-label="Onze aanpak" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">02</span>Onze aanpak</p>
      <h2 class="h2">Eerst meten, dan bouwen: <span class="accent">de SmartScan</span>.</h2>

      <div class="frame-body">
      <div class="steps" style="margin-top: 40px; align-content: start; grid-template-columns: repeat(4, 1fr);">

        <div class="step" style="--c: #00d8ff;">
          <div class="step-head">
            <span class="step-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
            </span>
            <span class="big-n">01</span>
          </div>
          <h4>Doorlichten</h4>
          <p>Processen, dossierflow en pijnpunten in kaart.</p>
        </div>

        <div class="step" style="--c: #8b5cf6;">
          <div class="step-head">
            <span class="step-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg>
            </span>
            <span class="big-n">02</span>
          </div>
          <h4>Prioriteren</h4>
          <p>Kansen rangschikken op impact én haalbaarheid.</p>
        </div>

        <div class="step" style="--c: #4f6cf7;">
          <div class="step-head">
            <span class="step-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </span>
            <span class="big-n">03</span>
