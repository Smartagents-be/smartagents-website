<section data-label="23 Voorbeeld 07 · Offertes">
  <div class="slide-frame split">

    <div style="flex: 1; padding: var(--pad-top) 80px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column;">
      <div style="display: flex; align-items: baseline; gap: 20px;">
        <span style="font-size: 88px; font-weight: 500; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; letter-spacing: -0.03em;">07</span>
        <span class="eyebrow">Voorbeeld</span>
      </div>
      <div class="bs-pills" style="margin-top: 22px;">
        <span class="bs-pill" style="--c: #06b6d4;">LLM</span>
        <span class="bs-pill" style="--c: #4f6cf7;">RAG</span>
        <span class="bs-pill" style="--c: #f59e0b;">Tools</span>
        <span class="bs-pill" style="--c: #8b5cf6;">Agents</span>
      </div>
      <h2 class="title" style="margin-top: 24px;">Offertes, klaar terwijl<br/>je nog aan het bellen bent.</h2>
      <p class="body" style="margin-top: 32px;">
        Eén agent leest alle bronnen en stelt een samenvatting op. Een tweede maakt daarmee de offerte op in jouw huisstijl. Jij keurt goed en verstuurt.
      </p>

      <div style="margin-top: 44px; display: inline-flex; align-items: center; gap: 20px;">
        <span style="font-size: 30px; color: var(--ink-4); text-decoration: line-through;">~2 uur</span>
        <span style="font-size: 28px; color: var(--ink-4);">→</span>
        <span style="font-size: 44px; font-weight: 700; color: var(--accent); letter-spacing: -0.02em;">~10 minuten</span>
      </div>

    </div>

    <div style="flex: 0 0 760px; background: var(--bg-alt); padding: 48px 60px; display: flex; align-items: center; justify-content: center;">
      <!-- animated two-agent offer generator (mirrors my-video/OfferteAgentCard) -->
      <div id="off-demo" style="width: 100%; max-width: 600px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 24px; box-shadow: 0 20px 50px rgba(15,23,42,0.10); overflow: hidden;">

        <!-- ① Agent 1 — verzamelt -->
        <div id="off-a1" class="off-step" style="display: flex; align-items: center; gap: 12px; padding: 18px 26px; border-bottom: 1px solid var(--border-soft);">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #06b6d4; box-shadow: 0 0 8px #06b6d4; flex-shrink: 0;"></span>
          <span style="font-size: 21px; font-weight: 700; color: #06b6d4; letter-spacing: 0.02em;">① Agent 1</span>
          <span style="font-size: 19px; color: var(--ink-4);">verzamelt de bronnen</span>
          <span id="off-a1-status" style="margin-left: auto; font-size: 18px; font-weight: 600; color: #06b6d4;"></span>
        </div>

        <div style="padding: 4px 26px;">
          <div class="off-src off-step" style="display: flex; gap: 13px; align-items: center; padding: 12px 0;">
            <div style="width: 42px; height: 42px; border-radius: 11px; background: color-mix(in srgb, #4f6cf7 13%, transparent); color: #4f6cf7; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 21px; font-weight: 600; color: var(--ink);">CRM</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 1px;">Janssen BV · contactgegevens</div>
            </div>
            <span class="off-state"><span class="ld">Laden…</span><span class="dn">✓ data</span></span>
          </div>

          <div class="off-src off-step" style="display: flex; gap: 13px; align-items: center; padding: 12px 0; border-top: 1px solid var(--border-soft);">
            <div style="width: 42px; height: 42px; border-radius: 11px; background: color-mix(in srgb, #8b5cf6 13%, transparent); color: #8b5cf6; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 21px; font-weight: 600; color: var(--ink);">ERP</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 1px;">panelen &amp; omvormers · prijzen</div>
            </div>
            <span class="off-state"><span class="ld">Laden…</span><span class="dn">✓ data</span></span>
          </div>

          <div class="off-src off-step" style="display: flex; gap: 13px; align-items: center; padding: 12px 0; border-top: 1px solid var(--border-soft);">
            <div style="width: 42px; height: 42px; border-radius: 11px; background: color-mix(in srgb, #06b6d4 13%, transparent); color: #06b6d4; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 21px; font-weight: 600; color: var(--ink);">E-mail</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 1px;">scope: 40 panelen, plat dak</div>
            </div>
            <span class="off-state"><span class="ld">Laden…</span><span class="dn">✓ data</span></span>
          </div>

          <div class="off-src off-step" style="display: flex; gap: 13px; align-items: center; padding: 12px 0; border-top: 1px solid var(--border-soft);">
            <div style="width: 42px; height: 42px; border-radius: 11px; background: color-mix(in srgb, #f59e0b 13%, transparent); color: #f59e0b; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 21px; font-weight: 600; color: var(--ink);">Dossier</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 1px;">referentie: € 6.200-project</div>
            </div>
            <span class="off-state"><span class="ld">Laden…</span><span class="dn">✓ data</span></span>
          </div>
        </div>

        <div id="off-summary" class="off-step" style="margin: 4px 20px 16px; padding: 12px 18px; border-radius: 12px; background: color-mix(in srgb, #06b6d4 8%, transparent); border: 1px solid color-mix(in srgb, #06b6d4 22%, transparent); font-size: 19px; color: var(--ink-2); font-weight: 600; display: flex; align-items: center; gap: 10px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><polyline points="20 6 9 17 4 12"/></svg>
          Samenvatting klaar, doorgegeven aan Agent 2
        </div>

        <!-- ② Agent 2 — maakt de offerte -->
        <div id="off-a2" class="off-step" style="border-top: 1px solid var(--border-soft); padding: 16px 26px 22px;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: #8b5cf6; box-shadow: 0 0 8px #8b5cf6; flex-shrink: 0;"></span>
            <span style="font-size: 21px; font-weight: 700; color: #8b5cf6; letter-spacing: 0.02em;">② Agent 2</span>
            <span style="font-size: 19px; color: var(--ink-4);">maakt de offerte op</span>
            <span id="off-a2-status" style="margin-left: auto; font-size: 18px; font-weight: 600; color: #8b5cf6;"></span>
          </div>

          <div style="margin-top: 14px; border: 1px solid var(--border-soft); border-radius: 12px; overflow: hidden; background: var(--bg);">
            <div style="display: flex; align-items: center; gap: 9px; padding: 11px 16px; background: color-mix(in srgb, #8b5cf6 7%, transparent); border-bottom: 1px solid var(--border-soft);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span style="font-size: 18px; font-weight: 600; color: var(--ink);">Offerte_Janssen_BV.pdf</span>
            </div>
            <div style="padding: 2px 16px;">
              <div class="off-field off-step" style="display: flex; justify-content: space-between; padding: 9px 0; font-size: 19px;"><span style="color: var(--ink-4);">Klant</span><span style="color: var(--ink); font-weight: 600;">Janssen BV</span></div>
              <div class="off-field off-step" style="display: flex; justify-content: space-between; padding: 9px 0; font-size: 19px; border-top: 1px solid var(--border-soft);"><span style="color: var(--ink-4);">Project</span><span style="color: var(--ink); font-weight: 600;">Zonnepanelen installatie</span></div>
              <div class="off-field off-step" style="display: flex; justify-content: space-between; padding: 9px 0; font-size: 19px; border-top: 1px solid var(--border-soft);"><span style="color: var(--ink-4);">Bedrag</span><span style="color: var(--accent); font-weight: 700; font-variant-numeric: tabular-nums;">€ 14.800</span></div>
              <div class="off-field off-step" style="display: flex; justify-content: space-between; padding: 9px 0; font-size: 19px; border-top: 1px solid var(--border-soft);"><span style="color: var(--ink-4);">Looptijd</span><span style="color: var(--ink); font-weight: 600;">3 weken</span></div>
              <div class="off-field off-step" style="display: flex; justify-content: space-between; padding: 9px 0; font-size: 19px; border-top: 1px solid var(--border-soft);"><span style="color: var(--ink-4);">Geldig tot</span><span style="color: var(--ink); font-weight: 600;">31 augustus 2026</span></div>
            </div>
            <div style="display: flex; justify-content: center; padding: 12px 16px; border-top: 1px solid var(--border-soft);">
              <span id="off-badge" class="off-badge" style="display: inline-flex; align-items: center; gap: 8px; background: color-mix(in srgb, #8b5cf6 12%, transparent); border: 1px solid color-mix(in srgb, #8b5cf6 40%, transparent); color: #8b5cf6; border-radius: 999px; padding: 7px 16px; font-size: 18px; font-weight: 700;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Offerte.pdf gereed
              </span>
            </div>
          </div>
        </div>

        <!-- ③ Jij — keurt goed -->
        <div id="off-jij" class="off-step" style="margin: 0 20px 20px; background: var(--surface); border: 1.5px solid color-mix(in srgb, #10b981 30%, var(--border-soft)); border-radius: 14px; padding: 14px 18px; display: flex; align-items: center; gap: 14px;">
          <div style="display: flex; align-items: center; gap: 7px; flex-shrink: 0;">
            <span style="width: 10px; height: 10px; border-radius: 50%; background: #10b981; box-shadow: 0 0 8px #10b981;"></span>
            <span style="font-size: 19px; font-weight: 700; color: #10b981;">③ Jij</span>
          </div>
          <div style="flex: 1; min-width: 0; position: relative; height: 24px; overflow: hidden;">
            <span id="off-jij-wait" class="off-fade" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: flex-start; font-size: 18px; color: var(--ink-4); font-style: italic; white-space: nowrap;">Wacht op goedkeuring…</span>
            <span id="off-jij-done" class="off-fade" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: flex-start; font-size: 18px; color: #10b981; font-weight: 700; white-space: nowrap;">✓ Goedgekeurd</span>
          </div>
          <span id="off-btn" class="off-btn" style="flex-shrink: 0; padding: 9px 18px; border-radius: 9px; font-size: 18px; font-weight: 700; letter-spacing: 0.01em; white-space: nowrap;">Goedkeuren</span>
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>23 / 32</div>
    </div>
  </div>
</section>
