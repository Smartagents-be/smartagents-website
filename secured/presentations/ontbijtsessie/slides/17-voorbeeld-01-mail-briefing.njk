            <div style="background: var(--surface); border: 1px solid var(--border-soft); border-radius: 14px; padding: 16px 18px; display: flex; align-items: center; gap: 14px;">
              <div style="width: 42px; height: 42px; border-radius: 11px; background: rgba(8,145,178,0.10); color: #0891b2; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
