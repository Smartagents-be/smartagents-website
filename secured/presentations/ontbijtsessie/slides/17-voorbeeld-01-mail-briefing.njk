            </div>
          </div>

          <!-- AI briefing -->
          <div style="margin-top: 20px; background: color-mix(in srgb, var(--accent) 5%, var(--bg-alt)); border-left: 5px solid var(--accent); border-radius: 6px 14px 14px 6px; padding: 20px 24px;">
