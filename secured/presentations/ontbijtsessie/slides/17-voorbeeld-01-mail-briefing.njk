          <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;">
            <div>
              <div style="font-size: 27px; font-weight: 700; color: var(--ink); letter-spacing: -0.01em;">Inbox Briefing</div>
            </div>
            <div style="display: inline-flex; align-items: center; gap: 9px; flex-shrink: 0; background: var(--bg-alt); border: 1px solid var(--border-soft); border-radius: 999px; padding: 8px 16px;">
