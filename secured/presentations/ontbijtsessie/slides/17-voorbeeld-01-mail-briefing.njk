              <span style="font-size: 17px; font-weight: 600; color: var(--ink-4); padding: 8px 18px;">Laatste 7d</span>
            </div>
            <span style="display: inline-flex; align-items: center; gap: 9px; font-size: 18px; font-weight: 700; color: #fff; background: linear-gradient(135deg, #0891b2, #06b6d4); border-radius: 12px; padding: 10px 22px; box-shadow: 0 8px 20px rgba(8,145,178,0.35);">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.7L19.6 10l-5.7 1.9L12 17.6l-1.9-5.7L4.4 10l5.7-1.9z"/><path d="M19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8z"/></svg>
              Briefing genereren
