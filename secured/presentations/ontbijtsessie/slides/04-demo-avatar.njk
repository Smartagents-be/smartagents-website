<section data-label="04 Demo · Avatar">
  <div class="slide-frame split">

    <div style="flex: 1; padding: var(--pad-top) 80px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column; justify-content: center;">
      <div class="eyebrow" style="color: #06b6d4;">Demo 01 · HeyGen-stijl</div>
      <h2 class="title" style="margin-top: 28px;">Een avatar die er<br/>uitziet <span class="accent">zoals ik.</span></h2>

      <div style="margin-top: 64px; display: flex; flex-direction: column; gap: 28px;">
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #06b6d4; font-variant-numeric: tabular-nums; min-width: 32px;">1</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">1 foto.</span>
        </div>
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #06b6d4; font-variant-numeric: tabular-nums; min-width: 32px;">2</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">1 voorbeeldtekst inspreken.</span>
        </div>
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #06b6d4; font-variant-numeric: tabular-nums; min-width: 32px;">3</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">5 minuten wachten op de render.</span>
        </div>
      </div>

      <div style="margin-top: 78px;">
        <div class="eyebrow" style="font-size: 18px; color: var(--ink-4);">Use-cases</div>
        <div style="display: flex; flex-wrap: wrap; gap: 14px; margin-top: 22px; max-width: 700px;">
          <span class="tag">Productvideo's</span>
          <span class="tag">Onboarding</span>
          <span class="tag">Training</span>
          <span class="tag">Klantenupdates</span>
          <span class="tag">Meertalige communicatie</span>
        </div>
      </div>
    </div>

    <div style="flex: 0 0 880px; background: var(--ink); position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center; overflow: hidden;">
      <!-- backdrop -->
      <div style="position: absolute; inset: 0; background:
            radial-gradient(ellipse 600px 500px at 50% 35%, rgba(34,211,238, 0.18), transparent 65%),
            linear-gradient(180deg, #1e293b 0%, #0f172a 100%);"></div>

      <div style="position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 40px;">
        <!-- avatar video -->
        <div style="width: 360px; height: 360px; border-radius: 50%; overflow: hidden; position: relative;
              border: 2px solid rgba(34,211,238, 0.4);
              box-shadow: 0 0 80px rgba(34,211,238, 0.25), inset 0 -40px 80px rgba(0,0,0,0.4);">
          <video id="avatar-video" src="assets/avatar_tom.mp4" poster="assets/avatar_tom_poster.jpg" playsinline preload="metadata"
                 style="width: 100%; height: 100%; object-fit: cover; object-position: 50% 28%; display: block; cursor: pointer;"></video>
        </div>

        <!-- custom playback controls -->
        <div class="avatar-controls">
          <button class="avatar-pp" id="avatar-pp" aria-label="Afspelen of pauzeren">
            <svg id="avatar-i-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg id="avatar-i-pause" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
          </button>
          <input class="avatar-seek" id="avatar-seek" type="range" min="0" max="100" value="0" step="0.1" aria-label="Zoeken in video">
          <span class="avatar-time" id="avatar-time">0:00 / 0:41</span>
        </div>
      </div>

    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>04 / 32</div>
    </div>
  </div>
</section>
