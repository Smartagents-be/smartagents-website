<section data-label="21 Voorbeeld 05 · Documenten doorzoeken">
  <div class="slide-frame split">

    <div style="flex: 1; padding: var(--pad-top) 80px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column;">
      <div style="display: flex; align-items: baseline; gap: 20px;">
        <span style="font-size: 88px; font-weight: 500; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; letter-spacing: -0.03em;">05</span>
        <span class="eyebrow">Voorbeeld</span>
      </div>
      <div class="bs-pills" style="margin-top: 22px;">
        <span class="bs-pill" style="--c: #06b6d4;">LLM</span>
        <span class="bs-pill" style="--c: #4f6cf7;">RAG</span>
      </div>
      <h2 class="title" style="margin-top: 24px;">Al je documenten,<br/>doorzoekbaar in mensentaal.</h2>
      <p class="body" style="margin-top: 32px;">
        Eén zoekbalk over élk document dat je organisatie wil ontsluiten: contracten, procedures, handleidingen, polissen, productfiches. Geen bladeren door mappen en pdf's meer.
      </p>

      <div style="margin-top: 56px; display: grid; grid-template-columns: 1fr 1fr; gap: 32px;">
        <div>
          <div class="eyebrow" style="color: var(--ink-4);">Tot het antwoord</div>
          <div style="font-size: 64px; font-weight: 600; color: var(--accent); margin-top: 8px; font-variant-numeric: tabular-nums; letter-spacing: -0.03em;">Seconden</div>
          <div class="small">in plaats van zelf zoeken</div>
        </div>
        <div>
          <div class="eyebrow" style="color: var(--ink-4);">Elk antwoord</div>
          <div style="font-size: 64px; font-weight: 600; color: var(--accent); margin-top: 8px; font-variant-numeric: tabular-nums; letter-spacing: -0.03em;">met bron</div>
          <div class="small">herleidbaar, dus niets verzonnen</div>
        </div>
      </div>

    </div>

    <div style="flex: 0 0 760px; background: var(--bg-alt); padding: 80px 60px; display: flex; align-items: center; justify-content: center;">
      <!-- search-first knowledge base -->
      <div style="width: 100%; max-width: 560px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 24px; box-shadow: 0 20px 50px rgba(15,23,42,0.10); overflow: hidden;">

        <!-- search bar -->
        <div style="padding: 26px 28px; border-bottom: 1px solid var(--border-soft);">
          <div style="display: flex; align-items: center; gap: 14px; background: var(--bg); border: 2px solid var(--accent); border-radius: 14px; padding: 16px 20px;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0891b2" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span style="flex: 1; font-size: 22px; color: var(--ink); line-height: 1.3;">Hoe reset ik Error 25 op een SolarEdge omvormer?</span>
            <span style="font-size: 18px; color: var(--ink-4); border: 1px solid var(--border-soft); border-radius: 6px; padding: 3px 9px;">⏎</span>
          </div>
        </div>

        <!-- results -->
        <div style="padding: 24px 28px; display: flex; flex-direction: column; gap: 18px;">
          <div style="display: flex; align-items: baseline; justify-content: space-between;">
            <span style="font-size: 19px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-4);">2 beste hits</span>
            <span style="font-size: 19px; color: var(--ink-4);">doorzocht je hele kennisbank</span>
          </div>

          <!-- hit 1 -->
          <div style="display: flex; gap: 16px; align-items: flex-start;">
            <div style="width: 34px; height: 34px; border-radius: 999px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 19px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">1</div>
            <div style="flex: 1;">
              <div style="font-size: 23px; font-weight: 600; color: var(--ink); line-height: 1.3;">Error 25: netspanning te hoog</div>
              <div style="font-size: 21px; color: var(--ink-3); line-height: 1.45; margin-top: 6px;">Omvormer ontkoppelt bij netspanning buiten 184–253 V. Reconnectie na 60 sec stabiel.</div>
              <div style="display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; background: var(--bg-alt); border: 1px solid var(--border-soft); border-radius: 999px; padding: 7px 13px; font-size: 18px; color: var(--accent); font-weight: 600;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                SolarEdge installatiehandleiding · p. 86
              </div>
            </div>
          </div>

          <div style="height: 1px; background: var(--border-soft);"></div>

          <!-- hit 2 -->
          <div style="display: flex; gap: 16px; align-items: flex-start;">
            <div style="width: 34px; height: 34px; border-radius: 999px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 19px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">2</div>
            <div style="flex: 1;">
              <div style="font-size: 23px; font-weight: 600; color: var(--ink); line-height: 1.3;">Service-bulletin: firmware v4.13</div>
              <div style="font-size: 21px; color: var(--ink-3); line-height: 1.45; margin-top: 6px;">Bij terugkerende Error 25: updaten naar v4.13.2 voor betere grid-tolerantie.</div>
              <div style="display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; background: var(--bg-alt); border: 1px solid var(--border-soft); border-radius: 999px; padding: 7px 13px; font-size: 18px; color: var(--accent); font-weight: 600;">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Bulletin SolarEdge BE · juli 2024
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>21 / 32</div>
    </div>
  </div>
</section>
