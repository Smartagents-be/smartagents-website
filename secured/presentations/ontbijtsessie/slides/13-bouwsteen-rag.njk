<section data-label="13 Bouwsteen · RAG" style="--accent: #4f6cf7;">
  <div class="slide-frame">
    <div style="display: flex; align-items: baseline; gap: 32px;">
      <span style="font-size: 24px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-4);">Bouwsteen 02 / 04</span>
      <span class="tag">RAG</span>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 80px; margin-top: 28px; align-items: start; flex: 1;">
      <div>
        <h2 class="title" style="margin-top: 0; font-size: 60px;">Retrieval-Augmented Generation.<br/><span style="display: inline-block; margin-top: 12px; font-size: 32px; line-height: 1.25; letter-spacing: -0.01em; color: var(--ink-3); font-weight: 400;">In gewone taal: AI met <span class="accent">jouw documenten</span> erbij.</span></h2>
        <p class="body" style="margin-top: 36px;">
          Voor élke vraag eerst zoeken in jouw kennisbank, dán antwoorden. Mét bronvermelding.
        </p>
        <div class="rule"></div>
        <div style="font-size: 24px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-4);">Wat het oplost</div>
        <div style="display: flex; flex-direction: column; gap: 18px; margin-top: 24px;">
          <div style="display: flex; gap: 20px; align-items: baseline;">
            <span style="font-size: 24px; font-weight: 700; color: var(--accent); min-width: 28px;">↳</span>
            <span style="font-size: 26px; line-height: 1.4; color: var(--ink-2);">Citeert in plaats van te verzinnen</span>
          </div>
          <div style="display: flex; gap: 20px; align-items: baseline;">
            <span style="font-size: 24px; font-weight: 700; color: var(--accent); min-width: 28px;">↳</span>
            <span style="font-size: 26px; line-height: 1.4; color: var(--ink-2);">Werkt op Office, PDF, e-mail, SharePoint</span>
          </div>
          <div style="display: flex; gap: 20px; align-items: baseline;">
            <span style="font-size: 24px; font-weight: 700; color: var(--accent); min-width: 28px;">↳</span>
            <span style="font-size: 26px; line-height: 1.4; color: var(--ink-2);">Elk antwoord herleidbaar naar de bron</span>
          </div>
        </div>
        <p style="font-size: 24px; line-height: 1.4; color: var(--ink-4); margin-top: 32px;">
          Jouw documenten, doorzoekbaar voor de AI.
        </p>
      </div>

      <!-- chat interface — grounded in your documents -->
      <div style="display: flex; flex-direction: column; gap: 16px;">
        <div style="background: var(--surface); border: 1px solid var(--border-soft); border-radius: 22px; box-shadow: 0 24px 60px rgba(15,23,42,0.07); overflow: hidden; display: flex; flex-direction: column;">

          <!-- window header -->
          <div style="display: flex; align-items: center; gap: 14px; padding: 22px 26px; border-bottom: 1px solid var(--border-soft);">
            <div style="width: 46px; height: 46px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            </div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 25px; font-weight: 700; color: var(--ink); line-height: 1.1;">AI-assistent</div>
              <div style="font-size: 20px; color: var(--ink-4); margin-top: 2px;">met jouw documenten</div>
            </div>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="var(--ink-4)"><circle cx="12" cy="5" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="12" cy="19" r="1.6"/></svg>
          </div>

          <!-- messages -->
          <div id="rag-demo" style="padding: 26px; display: flex; flex-direction: column; gap: 16px;">
            <!-- user question -->
            <div id="rag-q" class="rag-step" style="align-self: flex-end; max-width: 82%; background: var(--accent); color: #ffffff; border-radius: 20px 20px 6px 20px; padding: 18px 24px; font-size: 24px; line-height: 1.4;">Wat is de opzegtermijn bij klant Bekaert?</div>

            <!-- retrieval step -->
            <div id="rag-search" class="rag-step" style="width: 100%;">
              <div style="display: flex; align-items: center; gap: 10px; font-size: 20px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ink-4);">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Doorzoekt jouw kennisbank
                <span id="rag-dots" class="rag-dots"><span></span><span></span><span></span></span>
              </div>
              <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 12px;">

                <div class="rag-doc rag-step">
                  <svg class="rag-doc-ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ink-4)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span class="rag-doc-name">Contract Bekaert.pdf</span>
                  <span class="rag-doc-meta">2023</span>
                </div>

                <div id="rag-hit" class="rag-doc rag-step">
                  <svg class="rag-doc-ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ink-4)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <span class="rag-doc-name">Addendum 2024.pdf</span>
                  <span id="rag-badge" class="rag-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    art. 8.2
                  </span>
                </div>

                <div class="rag-doc rag-step">
                  <svg class="rag-doc-ico" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ink-4)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  <span class="rag-doc-name">Mail Verhaegen</span>
                  <span class="rag-doc-meta">apr. 2024</span>
                </div>

              </div>
            </div>

            <!-- grounded answer -->
            <div id="rag-a" class="rag-step" style="align-self: flex-start; max-width: 92%; background: var(--bg-alt); color: var(--ink-2); border-radius: 20px 20px 20px 6px; padding: 18px 24px; font-size: 24px; line-height: 1.45;">
              Drie maanden. Het staat in artikel 8.2 van het addendum (mei 2024).
              <div style="display: inline-flex; align-items: center; gap: 8px; margin-top: 14px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 999px; padding: 8px 14px; font-size: 19px; color: var(--accent); font-weight: 600;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                Addendum 2024.pdf · art. 8.2
              </div>
            </div>
          </div>

          <!-- input bar -->
          <div style="display: flex; align-items: center; gap: 14px; padding: 20px 22px; border-top: 1px solid var(--border-soft);">
            <div style="flex: 1; background: var(--bg-alt); border-radius: 999px; padding: 16px 24px; font-size: 22px; color: var(--ink-4);">Stel een vraag over je documenten…</div>
            <div style="width: 52px; height: 52px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>13 / 32</div>
    </div>
  </div>
</section>
