<section data-label="18 Voorbeeld 02 · Mail-triage">
  <div class="slide-frame split">

    <div style="flex: 1; padding: var(--pad-top) 64px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column;">
      <div style="display: flex; align-items: baseline; gap: 20px;">
        <span style="font-size: 88px; font-weight: 500; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; letter-spacing: -0.03em;">02</span>
        <span class="eyebrow">Voorbeeld</span>
      </div>
      <div class="bs-pills" style="margin-top: 22px;">
        <span class="bs-pill" style="--c: #06b6d4;">LLM</span>
        <span class="bs-pill" style="--c: #f59e0b;">Tools</span>
        <span class="bs-pill" style="--c: #8b5cf6;">Agents</span>
      </div>
      <h2 class="title" style="margin-top: 24px;">Triage + conceptantwoord.</h2>
      <p class="body" style="margin-top: 32px; max-width: 640px;">
        Vanuit de briefing duikt de agent in elke dringende mail. Hij vat samen, stelt een actie voor en schrijft meteen een antwoord in jouw toon.
      </p>
      <p class="body" style="margin-top: 20px; max-width: 640px; color: var(--ink-3);">
        Jij klikt verzenden, of stuurt bij.
      </p>
    </div>

    <div style="flex: 0 0 1000px; background: var(--bg-alt); padding: 44px 52px; display: flex; align-items: center; justify-content: center;">
      <!-- Triage view (mirrors the real SmartAgents app) -->
      <div style="width: 100%; max-width: 900px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 20px; box-shadow: 0 24px 60px rgba(15,23,42,0.14); padding: 30px 34px;">

        <!-- header -->
        <div style="display: flex; align-items: center; justify-content: space-between; padding-bottom: 18px; border-bottom: 1px solid var(--border-soft);">
          <div style="font-size: 28px; font-weight: 700; color: var(--ink); letter-spacing: -0.01em;">Dringend · actie nodig</div>
          <div style="width: 40px; height: 40px; border-radius: 999px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; color: var(--ink-3); font-variant-numeric: tabular-nums;">6</div>
        </div>

        <!-- group label -->
        <div style="display: flex; align-items: center; gap: 12px; margin-top: 20px;">
          <span style="display: inline-flex; align-items: center; gap: 9px; background: rgba(220,38,38,0.08); border-radius: 999px; padding: 7px 16px;">
            <span style="width: 9px; height: 9px; border-radius: 999px; background: #dc2626;"></span>
            <span style="font-size: 19px; font-weight: 700; color: #dc2626;">Klacht</span>
          </span>
          <span style="width: 32px; height: 32px; border-radius: 999px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 17px; font-weight: 700; color: var(--ink-3);">4</span>
        </div>

        <!-- expanded card: Peter De Ridder -->
        <div style="margin-top: 16px; background: var(--bg-alt); border: 1px solid var(--border-soft); border-radius: 14px; padding: 22px 24px;">

          <div style="display: flex; align-items: center; justify-content: space-between;">
            <div style="display: flex; align-items: center; gap: 12px;">
              <span style="width: 11px; height: 11px; border-radius: 999px; background: #dc2626; flex-shrink: 0;"></span>
              <span style="font-size: 23px; font-weight: 700; color: var(--ink);">Peter De Ridder</span>
            </div>
            <span style="font-size: 18px; color: var(--ink-4);">3 jun, 09:25</span>
          </div>

          <div style="font-size: 21px; font-weight: 700; color: var(--ink); margin-top: 14px;">Garantieclaim omvormer · dossier GC-2026-0034</div>
          <p style="font-size: 19px; line-height: 1.5; color: var(--ink-3); margin: 8px 0 0;">
            Growatt-omvormer (geïnstalleerd april 2025) defect met foutcode F-23. Herstarten loste niets op, de installatie produceert geen stroom meer. Vraagt een snelle afhandeling onder garantie.
          </p>

          <!-- AI suggested action -->
          <div style="display: flex; align-items: flex-start; gap: 11px; margin-top: 16px; padding-left: 14px; border-left: 3px solid #0d9488;">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px;"><path d="M12 3l1.9 5.7L19.6 10l-5.7 1.9L12 17.6l-1.9-5.7L4.4 10l5.7-1.9z"/></svg>
            <span style="font-size: 19px; line-height: 1.4; color: #0d9488; font-family: 'Fraunces', serif; font-style: italic;">Neem contact op met de klant en plan een technicus in voor een herstelling onder garantie.</span>
          </div>

          <div style="height: 1px; background: var(--border-soft); margin: 20px 0 18px;"></div>

          <!-- open in outlook -->
          <div style="display: inline-flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 600; color: var(--ink-3);">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
            Openen in Outlook
          </div>

          <!-- draft reply editor -->
          <div style="margin-top: 14px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 14px; padding: 18px 20px;">
            <div style="display: flex; align-items: center; justify-content: space-between; gap: 12px;">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-size: 18px; color: var(--ink-4);">Toon</span>
                <span style="display: inline-flex; align-items: center; gap: 10px; background: var(--bg-alt); border: 1px solid var(--border-soft); border-radius: 10px; padding: 8px 14px; font-size: 18px; font-weight: 600; color: var(--ink-2);">
                  Zakelijk
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </div>
              <div style="display: flex; align-items: center; gap: 18px; color: var(--ink-4);">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </div>
            </div>

            <div style="margin-top: 14px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 10px; padding: 18px 20px; font-size: 18px; line-height: 1.55; color: var(--ink-2);">
              Beste Peter,<br><br>
              Bedankt voor je bericht. We begrijpen dat het erg vervelend is dat je Growatt-omvormer momenteel een storing geeft en we lossen dit graag zo snel mogelijk voor je op.<br><br>
              Omdat de installatie minder dan twee jaar oud is, valt deze onder de garantie. We zetten de herstelling intern in gang en nemen snel contact met je op om een afspraak te plannen.
            </div>
          </div>
        </div>

      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>18 / 32</div>
    </div>
  </div>
</section>
