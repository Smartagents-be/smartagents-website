<section data-label="26 Voorbeeld 10 · Aanbestedingen">
  <div class="slide-frame split">

    <div style="flex: 0 0 620px; padding: var(--pad-top) 64px var(--pad-bottom) var(--pad-x); display: flex; flex-direction: column;">
      <div style="display: flex; align-items: baseline; gap: 20px;">
        <span style="font-size: 88px; font-weight: 500; color: var(--accent); font-variant-numeric: tabular-nums; line-height: 1; letter-spacing: -0.03em;">10</span>
        <span class="eyebrow">Voorbeeld</span>
      </div>
      <div class="bs-pills" style="margin-top: 22px;">
        <span class="bs-pill" style="--c: #06b6d4;">LLM</span>
        <span class="bs-pill" style="--c: #4f6cf7;">RAG</span>
        <span class="bs-pill" style="--c: #f59e0b;">Tools</span>
        <span class="bs-pill" style="--c: #8b5cf6;">Agents</span>
      </div>
      <h2 class="title" style="margin-top: 28px;">De juiste kansen,<br/>vanzelf bovenaan.</h2>
      <p class="body" style="margin-top: 30px;">
        De agent scant doorlopend je bronnen en houdt enkel over wat in jouw zoekprofiel past. Je team werkt alleen nog aan de kansen die tellen.
      </p>
    </div>

    <div style="flex: 1; background: var(--bg-alt); padding: 56px 72px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 18px;">

      <!-- zoekprofiel + bronnen — wat de agent zoekt en waar -->
      <div style="width: 100%; max-width: 820px; background: color-mix(in srgb, var(--accent-3) 8%, var(--surface)); border: 2px solid var(--accent-3); border-radius: 18px; box-shadow: 0 14px 36px color-mix(in srgb, var(--accent-3) 22%, transparent); padding: 22px 28px;">
        <div style="display: flex; align-items: center; gap: 14px;">
          <span style="display: inline-flex; align-items: center; gap: 8px; font-size: 19px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-3);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Zoekprofiel
          </span>
          <span style="font-size: 22px; font-weight: 700; color: var(--ink);">Industriebouw</span>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px;">
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">Stalen structuur</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">5.000–15.000 m²</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">Bedrijfspand</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">BE + grensregio</span>
        </div>

        <div style="height: 1px; background: color-mix(in srgb, var(--accent-3) 22%, transparent); margin: 18px 0;"></div>

        <div style="display: inline-flex; align-items: center; gap: 8px; font-size: 19px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent-3);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
          Bronnen die hij scant
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px;">
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">TED</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">e-Notification</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">BOAMP</span>
          <span style="background: color-mix(in srgb, var(--accent-3) 12%, transparent); color: var(--accent-3); border-radius: 999px; padding: 7px 15px; font-size: 20px; font-weight: 600;">Tenderned</span>
        </div>
      </div>

      <!-- ranked opportunities with visible matching action (example: tenders) -->
      <div style="width: 100%; max-width: 820px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 24px; box-shadow: 0 20px 50px rgba(15,23,42,0.10); overflow: hidden;">

        <!-- scan → filter → scope funnel -->
        <div style="display: flex; align-items: center; gap: 18px; padding: 22px 30px; border-bottom: 1px solid var(--border-soft);">
          <span style="display: inline-flex; align-items: center; gap: 9px; font-size: 21px; font-weight: 700; color: var(--accent);">
            <span style="width: 11px; height: 11px; border-radius: 999px; background: var(--accent); box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 20%, transparent);"></span>
            Tender Matcher
          </span>
          <div style="flex: 1; display: flex; align-items: center; justify-content: flex-end; gap: 14px; font-size: 20px; color: var(--ink-4);">
            <span><b style="color: var(--ink-2);">47</b> gescand</span>
            <span style="color: var(--ink-4);">→</span>
            <span><b style="color: var(--ink-2);">11</b> relevant</span>
            <span style="color: var(--ink-4);">→</span>
            <span style="color: var(--accent); font-weight: 700;">6 in scope</span>
          </div>
        </div>

        <!-- TOP MATCH, expanded: why it matches -->
        <div style="padding: 26px 30px; border-bottom: 1px solid var(--border-soft); background: color-mix(in srgb, var(--accent) 4%, transparent);">
          <div style="display: flex; align-items: flex-start; gap: 18px;">
            <div style="width: 46px; height: 46px; border-radius: 10px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 18px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">BE</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 25px; font-weight: 700; color: var(--ink); line-height: 1.2;">Distributiecentrum 8.500 m² · Westerlo</div>
              <div style="font-size: 20px; color: var(--ink-4); margin-top: 4px;">e-Notification · publicatie 11/5 · deadline 30/5</div>
            </div>
            <div style="text-align: right; flex-shrink: 0;">
              <div style="font-size: 40px; font-weight: 700; color: var(--accent); line-height: 1;">91%</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">match</div>
            </div>
          </div>
          <!-- match criteria, mapped to the zoekprofiel -->
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px;">
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Stalen structuur</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>8.500 m²</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>Bedrijfspand</span>
            <span style="display: inline-flex; align-items: center; gap: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border-radius: 999px; padding: 7px 14px; font-size: 19px; font-weight: 600;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>België</span>
          </div>
        </div>

        <!-- next ranked rows -->
        <div style="padding: 6px 30px;">
          <div style="display: flex; align-items: center; gap: 18px; padding: 16px 0;">
            <div style="width: 40px; height: 40px; border-radius: 9px; background: rgba(8,145,178,0.12); color: var(--accent); font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">WA</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 22px; font-weight: 600; color: var(--ink); line-height: 1.25;">KMO-park, 6 units · Tournai</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">e-Notification · deadline 10/6</div>
            </div>
            <span style="font-size: 21px; font-weight: 700; color: var(--accent); min-width: 64px; text-align: right;">88%</span>
            <div style="width: 120px; height: 8px; border-radius: 999px; background: var(--border); overflow: hidden; flex-shrink: 0;"><div style="width: 88%; height: 100%; background: var(--accent);"></div></div>
          </div>
          <div style="display: flex; align-items: center; gap: 18px; padding: 16px 0; border-top: 1px solid var(--border-soft);">
            <div style="width: 40px; height: 40px; border-radius: 9px; background: rgba(180,83,9,0.12); color: var(--accent-warm); font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">NL</div>
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 22px; font-weight: 600; color: var(--ink); line-height: 1.25;">Logistiek magazijn 12.000 m² · Venlo</div>
              <div style="font-size: 18px; color: var(--ink-4); margin-top: 2px;">Tenderned · BREEAM vereist · deadline 20/6</div>
            </div>
            <span style="font-size: 21px; font-weight: 700; color: var(--accent-warm); min-width: 64px; text-align: right;">74%</span>
            <div style="width: 120px; height: 8px; border-radius: 999px; background: var(--border); overflow: hidden; flex-shrink: 0;"><div style="width: 74%; height: 100%; background: var(--accent-warm);"></div></div>
          </div>
        </div>

        <!-- filtered-out footer -->
        <div style="display: flex; align-items: center; gap: 10px; padding: 16px 30px; border-top: 1px solid var(--border-soft); font-size: 19px; color: var(--ink-4);">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          41 buiten scope, automatisch weggefilterd
        </div>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>26 / 32</div>
    </div>
  </div>
</section>
