<section data-label="06 Demo · Muziek">
  <div class="slide-frame split">

    <!-- LEFT · dark play panel -->
    <div style="flex: 0 0 880px; background: var(--ink); position: relative; display: flex; flex-direction: column; justify-content: center; align-items: center; overflow: hidden;">
      <!-- backdrop -->
      <div style="position: absolute; inset: 0; background:
            radial-gradient(ellipse 600px 500px at 50% 35%, rgba(34,211,238, 0.18), transparent 65%),
            linear-gradient(180deg, #1e293b 0%, #0f172a 100%);"></div>

      <div style="position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 40px;">
        <!-- vinyl disc -->
        <div style="width: 360px; height: 360px; border-radius: 50%; overflow: hidden; position: relative;
              border: 2px solid rgba(34,211,238, 0.4);
              box-shadow: 0 0 80px rgba(34,211,238, 0.25), inset 0 -40px 80px rgba(0,0,0,0.4);">
          <div id="music-disc" style="position: absolute; inset: 0;">
            <!-- colour wash -->
            <div style="position: absolute; inset: 0; background:
                  radial-gradient(ellipse at 22% 28%, #B45309, transparent 58%),
                  radial-gradient(ellipse at 80% 72%, #BE3455, transparent 58%),
                  linear-gradient(135deg, #0891b2, #1e293b);"></div>
            <!-- grooves -->
            <div style="position: absolute; inset: 0; background:
                  repeating-radial-gradient(circle at 50% 50%, rgba(0,0,0,0) 0, rgba(0,0,0,0) 9px, rgba(0,0,0,0.10) 9px, rgba(0,0,0,0.10) 11px);"></div>
            <!-- center label -->
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 104px; height: 104px; border-radius: 50%;
                  background: rgba(15,23,42,0.88); border: 1px solid rgba(34,211,238, 0.45);
                  display: flex; align-items: center; justify-content: center;">
              <div style="font-size: 16px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--on-dark-accent);">Suno</div>
            </div>
          </div>
        </div>

        <!-- audio + controls -->
        <audio id="music-player" src="assets/aviso-ochtendstart.mp3" preload="metadata"></audio>
        <div class="avatar-controls">
          <button class="avatar-pp" id="music-pp" aria-label="Afspelen of pauzeren">
            <svg id="music-i-play" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            <svg id="music-i-pause" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
          </button>
          <input class="avatar-seek" id="music-seek" type="range" min="0" max="100" value="0" step="0.1" aria-label="Zoeken in nummer">
          <span class="avatar-time" id="music-time">0:00 / 0:00</span>
        </div>
      </div>
    </div>

    <!-- RIGHT · light content -->
    <div style="flex: 1; padding: var(--pad-top) var(--pad-x) var(--pad-bottom) 80px; display: flex; flex-direction: column; justify-content: center;">
      <div class="eyebrow" style="color: #f59e0b;">Demo 03 · Suno</div>
      <h2 class="title" style="margin-top: 24px;">Een liedje<br/>over <span class="accent">jouw bedrijf.</span></h2>

      <div style="margin-top: 44px; display: flex; flex-direction: column; gap: 22px;">
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #f59e0b; font-variant-numeric: tabular-nums; min-width: 32px;">1</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">Eén prompt van een paar zinnen.</span>
        </div>
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #f59e0b; font-variant-numeric: tabular-nums; min-width: 32px;">2</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">Stijl en stem kiezen.</span>
        </div>
        <div style="display: flex; gap: 24px; align-items: baseline;">
          <span style="font-size: 24px; font-weight: 700; color: #f59e0b; font-variant-numeric: tabular-nums; min-width: 32px;">3</span>
          <span style="font-size: 30px; line-height: 1.35; color: var(--ink-2);">20 seconden wachten op de render.</span>
        </div>
      </div>

      <div style="margin-top: 44px;">
        <div class="eyebrow" style="font-size: 18px; color: var(--ink-4);">Use-cases</div>
        <div style="display: flex; flex-wrap: wrap; gap: 14px; margin-top: 22px; max-width: 720px;">
          <span class="tag">Achtergrondmuziek</span>
          <span class="tag">Wachtmuziek</span>
          <span class="tag">Social media</span>
          <span class="tag">Event-intro</span>
          <span class="tag">Podcast-intro</span>
        </div>
      </div>

      <div style="margin-top: 44px; background: var(--surface); border: 1px solid var(--border-soft); border-radius: 14px; padding: 20px 24px; max-width: 760px;">
        <div class="eyebrow" style="color: var(--ink-4); font-size: 18px;">Prompt</div>
        <p style="font-size: 21px; margin-top: 12px; line-height: 1.4; color: var(--ink-2); font-family: 'Fraunces', serif; font-style: italic;">
         "Een introductie bij een ontbijtsessie van Aviso+ over artificiële intelligentie. Een energieke ochtendstart: optimistisch over wat AI voor je werk kan betekenen. Schlager-rock met stevige gitaren en een meezingrefrein."
        </p>
      </div>
    </div>

    <div class="chrome">
      <div class="sa-brand on-dark"><img src="assets/logo.svg" alt="">Smart<span class="accent">Agents</span></div>
      <div>06 / 32</div>
    </div>
  </div>
</section>
