<!-- ════════════════ 16 · QUOTE — Strategie ════════════════ -->
  <section data-label="Strategie quote" class="slide light">
    <div class="frame" style="justify-content: center;">
      <p class="eyebrow" style="margin-bottom: 56px;">De juiste vraag</p>
      <div class="pullquote" style="max-width: 1600px;">
        <p class="q-text">
          <span style="color: #94a3b8; font-weight: 400;">Niet</span> "Wat moeten wij<br>
          <span style="color: #94a3b8; font-weight: 400;">doen met AI?"</span> — maar<br>
          <span class="accent">"Wat doet AI met ons?"</span>
        </p>
        <div class="q-byline">
          <span class="dot"></span>
          <span>SmartAgents · Strategie 2026</span>
        </div>
      </div>
    </div>
    {% set slideNumber = "16" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
