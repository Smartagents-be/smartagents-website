<!-- ════════════════ 26 · ROI — 4 kwadranten ════════════════ -->
  <section data-label="ROI" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">08</span>ROI</p>
      <h1 class="title" style="max-width: 1500px;">Waar zit jouw ROI?</h1>
      <p class="lede" style="margin-bottom: 56px;">ROI in AI is meer dan productiviteit. Vier kwadranten waarop je je voortgang kan beoordelen.</p>

      <div style="display: grid; grid-template-columns: 200px 1fr; gap: 16px; flex: 1;">
        <div style="display: flex; align-items: center; justify-content: center;">
          <span style="font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase; writing-mode: vertical-rl; transform: rotate(180deg);">↑ Competitief voordeel</span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 16px;">
          <div class="card" style="padding: 32px 32px; display: flex; flex-direction: column; gap: 8px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Kennis</div>
            <h3 style="font-size: 32px; margin: 0; font-weight: 600;">Slimmer</h3>
            <p style="font-size: 24px;">Bedrijfskennis ontsluiten en democratiseren voor wie ze nodig heeft.</p>
          </div>
          <div class="card" style="padding: 32px 32px; display: flex; flex-direction: column; gap: 8px; background: var(--sa-cyan-08); border-color: var(--sa-cyan-30);">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Hyper-personalisatie</div>
            <h3 style="font-size: 32px; margin: 0; font-weight: 600;">Persoonlijker</h3>
            <p style="font-size: 24px;">Producten, diensten en ervaringen op maat van de klant.</p>
          </div>
          <div class="card" style="padding: 32px 32px; display: flex; flex-direction: column; gap: 8px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Productiviteit</div>
            <h3 style="font-size: 32px; margin: 0; font-weight: 600;">Efficiënter</h3>
            <p style="font-size: 24px;">Dezelfde activiteit uitvoeren — maar sneller.</p>
          </div>
          <div class="card" style="padding: 32px 32px; display: flex; flex-direction: column; gap: 8px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Creativiteit</div>
            <h3 style="font-size: 32px; margin: 0; font-weight: 600;">Creatiever</h3>
            <p style="font-size: 24px;">Dezelfde activiteit uitvoeren — maar beter.</p>
          </div>
          <div style="grid-column: 1 / -1; padding-top: 8px; text-align: right; font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase;">Kwaliteit →</div>
        </div>
      </div>
    </div>
    {% set slideNumber = "26" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
