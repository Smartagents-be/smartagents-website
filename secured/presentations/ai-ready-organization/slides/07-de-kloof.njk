<!-- ════════════════ 07 · DE KLOOF ════════════════ -->
  <section data-label="De kloof" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow">De kloof</p>
      <h2 class="h2" style="max-width: 1500px;">Wat je individueel wint, win je niet automatisch <span class="accent">als organisatie</span>.</h2>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-top: 80px;">
        <div class="card" style="padding: 56px 48px;">
          <div class="ey">Persoonlijk niveau</div>
          <div style="display: flex; align-items: baseline; gap: 18px; margin: 12px 0 20px;">
            <span class="stat" style="font-size: 156px;">+25</span>
            <span style="font-size: 36px; color: var(--fg-muted); font-weight: 500;">min / dag</span>
          </div>
          <p style="font-size: 26px; line-height: 1.45; color: var(--fg-muted); margin: 0;">
            Tijdwinst per dag — gemiddeld — bij werknemers die AI-chatbots gebruiken.
          </p>
          <p class="source">Bron · NBER, 2025</p>
        </div>

        <div class="card" style="padding: 56px 48px; border-color: var(--sa-white-07); background: var(--sa-dark-deep);">
          <div class="ey" style="color: var(--fg-muted);">Organisatie­niveau</div>
          <div style="display: flex; align-items: baseline; gap: 18px; margin: 12px 0 20px;">
            <span class="stat" style="font-size: 156px; color: var(--fg);">0</span>
            <span style="font-size: 36px; color: var(--fg-muted); font-weight: 500;">meetbaar effect</span>
          </div>
          <p style="font-size: 26px; line-height: 1.45; color: var(--fg-muted); margin: 0;">
            Datzelfde onderzoek vindt vooralsnog geen weerslag in bedrijfsresultaten.
          </p>
          <p class="source">Bron · NBER, 2025</p>
        </div>
      </div>

      <p class="small" style="margin-top: 56px; max-width: 1500px; font-size: 26px; color: var(--fg-muted);">
        Vrije tijd in het hoofd van een medewerker is nog geen waarde op de jaarrekening. Daar zit de eigenlijke uitdaging.
      </p>
    </div>
    {% set slideNumber = "07" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
