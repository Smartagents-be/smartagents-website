<!-- ════════════════ 13 · DYNAMIEK 02 ════════════════ -->
  <section data-label="Dynamiek 02" class="slide light">
    <div class="glow"></div>
    <div class="frame" style="justify-content: center;">
      <p class="eyebrow">Dynamiek 02 · Efficiëntie ≠ einddoel</p>
      <h1 class="title" style="max-width: 1600px;">Tijd vrijspelen is<br><span class="accent">nog geen strategie</span>.</h1>
      <p class="body" style="font-size: 30px; margin-top: 32px; max-width: 1500px;">
        Efficiëntie en kostenbesparing zijn niet hetzelfde — en efficiëntie is zelden het einddoel. Echte waarde ontstaat pas wanneer een organisatie weet wat ze met de vrijgekomen tijd, capaciteit en middelen wíl doen.
      </p>
      <p style="font-size: 30px; line-height: 1.45; margin-top: 36px; max-width: 1500px; color: var(--fg);">
        Zonder dat antwoord blijft AI een persoonlijke productiviteits-hack, geen structurele meerwaarde.
      </p>

      <div style="margin-top: 64px; padding: 36px 44px; border-left: 3px solid var(--sa-cyan); max-width: 1400px; background: var(--sa-cyan-08); border-radius: 0 16px 16px 0;">
        <p style="font-size: 32px; line-height: 1.35; color: var(--fg); margin: 0; font-style: italic; font-weight: 500;">
          "Efficiëntie wordt pas meerwaarde wanneer de vrijgekomen tijd strategisch wordt ingezet."
        </p>
      </div>
    </div>
    {% set slideNumber = "13" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
