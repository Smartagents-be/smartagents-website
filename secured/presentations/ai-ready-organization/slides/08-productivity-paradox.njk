<!-- ════════════════ 08 · PRODUCTIVITY PARADOX ════════════════ -->
  <section data-label="Productivity paradox" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">03</span>De productivity paradox</p>
      <h1 class="title" style="max-width: 1500px;">De winst voelt groot.<br>De cijfers <span class="accent">zwijgen nog</span>.</h1>

      <div class="grid-2-side" style="margin-top: 48px; align-items: center;">
        <p class="body" style="font-size: 28px; max-width: 800px;">
          AI maakt op individueel vlak meteen indruk. Maar tussen dat eerste enthousiasme en zichtbare bedrijfsresultaten ligt een fase waarin de organisatie zelf moet veranderen — processen, rollen, beslissingsmodellen. Pas daarna volgt de echte sprong.
        </p>

        <!-- Chart: expectation vs reality -->
        <div class="chart-card" style="position: relative; aspect-ratio: 16 / 9; max-width: 800px; width: 100%; padding: 24px;">
          <svg viewBox="0 0 800 500" width="100%" height="100%" preserveAspectRatio="xMidYMid meet">
            <!-- axes -->
            <line x1="60" y1="440" x2="780" y2="440" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"/>
            <line x1="60" y1="40" x2="60" y2="440" stroke="rgba(255,255,255,0.18)" stroke-width="1.5"/>
            <text x="780" y="476" text-anchor="end" fill="rgba(255,255,255,0.55)" font-size="24" font-family="Inter">Tijd →</text>
            <text x="48" y="36" text-anchor="end" fill="rgba(255,255,255,0.55)" font-size="24" font-family="Inter" transform="rotate(-90 48 36)">Impact</text>
            <!-- expectation: straight steep -->
            <path d="M60,440 L780,80" stroke="rgba(255,255,255,0.35)" stroke-width="3" stroke-dasharray="8 8" fill="none"/>
            <text x="690" y="68" fill="rgba(255,255,255,0.7)" font-size="24" font-family="Inter">Verwachting</text>
            <!-- reality: S-curve -->
            <path d="M60,440 C220,430 280,420 360,350 C440,280 480,250 540,180 C620,90 720,70 780,60"
                  stroke="#22d3ee" stroke-width="5" fill="none" stroke-linecap="round"/>
            <text x="690" y="36" fill="#22d3ee" font-size="24" font-weight="600" font-family="Inter">Realiteit</text>
            <!-- labels -->
            <g font-family="Inter" font-size="24" fill="rgba(255,255,255,0.7)">
              <text x="200" y="380">Overschatting</text>
              <text x="500" y="430">Onderschatting</text>
            </g>
          </svg>
        </div>
      </div>

      <p class="small" style="margin-top: 48px; font-size: 24px; font-style: italic; color: var(--fg-muted); max-width: 1500px;">
        "You can see the computer age everywhere — except in the productivity statistics." <span style="color: var(--fg-subtle); font-style: normal;">— Robert Solow, 1987</span>
      </p>
    </div>
    {% set slideNumber = "08" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
