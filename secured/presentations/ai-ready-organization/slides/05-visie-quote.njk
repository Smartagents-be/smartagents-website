<!-- ════════════════ 05 · QUOTE — Visie ════════════════ -->
  <section data-label="Visie quote" class="slide light">
    <div class="frame" style="justify-content: center;">
      <p class="eyebrow" style="margin-bottom: 64px;">Onze visie</p>
      <div class="pullquote">
        <p class="q-text"><span style="color: rgb(255, 255, 255)"></span>
          De winst van AI komt niet uit de<br>
          technologie zelf. <span class="accent">Ze komt uit de keuzes<br>die je erover maakt.</span>
        </p>
        <div class="q-byline">
          <span class="dot"></span>
          <span>SmartAgents · Visie 2026</span>
        </div>
      </div>
    </div>
    {% set slideNumber = "05" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
