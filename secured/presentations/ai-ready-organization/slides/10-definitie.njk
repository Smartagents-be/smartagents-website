  <section data-label="Definitie" class="slide light">
    <div class="glow soft"></div>
    <div class="frame">
      <p class="eyebrow">Definitie</p>
      <h2 class="h2" style="max-width: 1400px; margin-bottom: 56px;">Wat verstaan we onder<br>een AI-ready organisatie?</h2>

      <div class="grid-3">
        <div class="card">
          <div class="num-lg">01</div>
          <h3>Strategisch verankerd</h3>
