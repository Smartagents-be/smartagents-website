<!-- ════════════════ 24 · STAP 4 — ASSESSMENT 2x2 ════════════════ -->
  <section data-label="Stap 4" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <div class="step-strip">
        <span class="pill">Stap 1</span><span class="pill">Stap 2</span><span class="pill">Stap 3</span>
        <span class="sep">→</span>
        <span class="pill on">Stap 4 · Capability assessment</span>
        <span class="pill">Stap 5</span>
      </div>
      <h1 class="title" style="max-width: 1700px; font-size: 56px; margin-bottom: 28px;">Welke capabilities zijn opportuniteit, welke<br>zijn risico, welke gewoon een no-brainer?</h1>

      <div style="flex: 1; display: grid; grid-template-columns: 60px 1fr; grid-template-rows: 1fr auto; gap: 12px 16px; min-height: 0;">
        <!-- Y axis label -->
        <div style="display: flex; align-items: center; justify-content: center;">
          <span style="font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase; writing-mode: vertical-rl; transform: rotate(180deg); white-space: nowrap; font-weight: 600;">Specifiek &nbsp;↑↓&nbsp; Generiek</span>
        </div>

        <!-- 2x2 grid -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 16px; min-height: 0;">
          <!-- top-left -->
          <div style="border: 1px solid var(--sa-cyan-30); border-radius: 16px; padding: 28px 30px; background: var(--sa-cyan-08); display: flex; flex-direction: column; gap: 10px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">Differentiator</div>
            <h3 style="font-size: 32px; margin: 0; color: var(--fg); font-weight: 600;">Onderscheidende capabilities</h3>
            <p style="font-size: 24px; margin: 0; color: var(--fg-muted); line-height: 1.4;">Capabilities die jou kunnen onderscheiden in je markt.</p>
          </div>
          <!-- top-right -->
          <div style="border: 1px solid rgba(244,63,94,0.4); border-radius: 16px; padding: 28px 30px; background: rgba(244,63,94,0.08); display: flex; flex-direction: column; gap: 10px;">
            <div style="font-size: 24px; font-weight: 700; color: #f43f5e; letter-spacing: 0.18em; text-transform: uppercase;">Strategisch risico</div>
            <h3 style="font-size: 32px; margin: 0; color: var(--fg); font-weight: 600;">Bedreiging voor je voordeel</h3>
            <p style="font-size: 24px; margin: 0; color: var(--fg-muted); line-height: 1.4;">Capabilities die je competitief voordeel kunnen ondergraven.</p>
          </div>
          <!-- bottom-left -->
          <div style="border: 1px solid rgba(16,185,129,0.4); border-radius: 16px; padding: 28px 30px; background: rgba(16,185,129,0.08); display: flex; flex-direction: column; gap: 10px;">
            <div style="font-size: 24px; font-weight: 700; color: #10b981; letter-spacing: 0.18em; text-transform: uppercase;">No-brainer</div>
            <h3 style="font-size: 32px; margin: 0; color: var(--fg); font-weight: 600;">Gewoon doen</h3>
            <p style="font-size: 24px; margin: 0; color: var(--fg-muted); line-height: 1.4;">Lage kost, lage risico's — gewoon doen.</p>
          </div>
          <!-- bottom-right -->
          <div style="border: 1px solid var(--sa-white-10); border-radius: 16px; padding: 28px 30px; background: var(--sa-white-05); display: flex; flex-direction: column; gap: 10px;">
            <div style="font-size: 24px; font-weight: 700; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase;">Money pit</div>
            <h3 style="font-size: 32px; margin: 0; color: var(--fg); font-weight: 600;">Vermijden</h3>
            <p style="font-size: 24px; margin: 0; color: var(--fg-muted); line-height: 1.4;">Hoge kost en risico, minimale return — vermijden.</p>
          </div>
          <!-- x-axis label -->
          <div style="grid-column: 1 / -1; display: flex; justify-content: space-between; padding-top: 8px; font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600;">
            <span>← Commodity-tech</span>
            <span>Gespecialiseerde tech →</span>
          </div>
        </div>
      </div>
    </div>
    {% set slideNumber = "24" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
