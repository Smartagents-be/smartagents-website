<!-- ════════════════ 20 · VISIE → STRATEGIE → AI ════════════════ -->
  <section data-label="Visie hiërarchie" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow">Stap 1 · Toelichting</p>
      <h1 class="title" style="max-width: 1600px;">AI-strategie staat ín dienst van<br>bedrijfsstrategie. <span style="color: var(--fg-muted);">Nooit omgekeerd.</span></h1>

      <div class="grid-2-side" style="margin-top: 56px; align-items: center; grid-template-columns: 0.85fr 1.15fr; gap: 56px;">
        <p class="body" style="font-size: 26px; max-width: 700px;">
          Een AI-strategie die niet voortkomt uit bedrijfsstrategie creëert geen waarde — ze creëert kosten. De juiste volgorde is helder: visie geeft strategie richting, strategie geeft de AI-strategie haar opdracht.
        </p>

        <!-- Hierarchy stack -->
        <div style="display: flex; flex-direction: column; gap: 18px; align-items: stretch; max-width: 960px; margin-left: auto; width: 100%;">
          <div style="padding: 36px 40px; border-radius: 16px; background: var(--sa-cyan-08); border: 1px solid var(--sa-cyan-30); display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 38px; font-weight: 600; color: var(--fg);">Visie</span>
            <span style="font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase;">is de basis voor</span>
          </div>
          <div style="text-align: center; color: var(--sa-cyan); font-size: 28px;">↓</div>
          <div style="padding: 36px 40px; border-radius: 16px; background: var(--sa-white-05); border: 1px solid var(--sa-white-10); display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 38px; font-weight: 600; color: var(--fg);">Strategie</span>
            <span style="font-size: 24px; color: var(--fg-muted); letter-spacing: 0.18em; text-transform: uppercase;">geeft richting aan</span>
          </div>
          <div style="text-align: center; color: var(--sa-cyan); font-size: 28px;">↓</div>
          <div style="padding: 36px 40px; border-radius: 16px; background: var(--sa-white-05); border: 1px solid var(--sa-white-10); display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 38px; font-weight: 600; color: var(--fg);">AI-strategie</span>
            <span style="font-size: 24px; color: var(--sa-cyan); letter-spacing: 0.18em; text-transform: uppercase;">draagt bij aan ↑</span>
          </div>
        </div>
      </div>
    </div>
    {% set slideNumber = "20" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
