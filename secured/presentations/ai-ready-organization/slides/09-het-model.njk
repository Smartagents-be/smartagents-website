<!-- ════════════════ 09 · HET MODEL ════════════════ -->
  <section data-label="Het model" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">04</span>Het model</p>
      <h1 class="title" style="max-width: 1400px;">De AI-ready organisatie.</h1>
      <p class="lede" style="margin-bottom: 56px;">Een AI-ready organisatie verankert AI op drie niveaus — en alleen samen vormen ze een geheel dat schaalt.</p>

      <div class="pillars" style="flex: 1;">
        <div class="pillar">
          <span class="lab">Niveau 01</span>
          <h3>Strategie</h3>
          <p>AI als deel van bedrijfsvisie en -strategie.</p>
          <ul>
            <li>AI-visie &amp; roadmap</li>
            <li>KPI's &amp; OKR's</li>
            <li>AI-beleid</li>
          </ul>
        </div>
        <div class="pillar">
          <span class="lab">Niveau 02</span>
          <h3>Verandermotor</h3>
          <p>Zonder mensen, geen AI.</p>
          <ul>
            <li>Change</li>
            <li>Communicatie</li>
            <li>Opleiding</li>
          </ul>
        </div>
        <div class="pillar">
          <span class="lab">Niveau 03</span>
          <h3>Enablers</h3>
          <p>De bouwstenen die AI op de juiste plek zetten.</p>
          <ul>
            <li>Talent &amp; organisatie</li>
            <li>Governance</li>
            <li>Technologie</li>
            <li>Data &amp; content</li>
            <li>Proces</li>
          </ul>
        </div>
      </div>
    </div>
    {% set slideNumber = "09" %}
    {% set slideTotal = "29" %}
    {% include "../../shared/chrome.njk" %}
  </section>
