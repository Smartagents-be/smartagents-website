<!-- ════════════════ 08 · VOORDELEN ════════════════ -->
  <section data-label="Voordelen" class="slide light">
    <div class="glow"></div>
    <div class="frame">
      <p class="eyebrow"><span class="num">07</span>Voordelen voor je bedrijf</p>
      <h1 class="title" style="max-width: 1500px;">Wat <span class="accent">AI-staffing oplevert</span><br>voor je organisatie.</h1>

      <div style="display: flex; flex-direction: column; flex: 1; justify-content: space-between; padding-bottom: 72px;">
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-top: 48px; align-items: stretch;">
          <div class="stat-block" style="min-height: 280px; justify-content: center;">
            <span class="num" style="font-size: 64px;">Sneller</span>
            <span class="lbl">De juiste expert aan tafel: een voorgescreende shortlist in plaats van maanden zoekwerk</span>
          </div>
          <div class="stat-block" style="min-height: 280px; justify-content: center;">
            <span class="num" style="font-size: 64px;">Sterker</span>
            <span class="lbl">Echte AI-kennis aan de selectietafel: minder mismatches, betere aanwervingen</span>
          </div>
          <div class="stat-block" style="min-height: 280px; justify-content: center;">
            <span class="num" style="font-size: 64px;">Duurzaam</span>
            <span class="lbl">Interne AI-capaciteit die meegroeit met je ambities en roadmap, via aanwerving én training</span>
          </div>
        </div>

        <p class="sec-note" style="font-size: 19px; margin: 0;">Elke aanwerving is anders: doorlooptijd en aanpak stemmen we af op jouw rol, stack en organisatie.</p>
      </div>
    </div>
    {% set slideNumber = "08" %}
    {% set slideTotal = "09" %}
    {% include "../../shared/chrome.njk" %}
  </section>
