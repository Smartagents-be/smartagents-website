    <section class="team-page-hero">
        <div class="container">
            <h1 class="section-title">{{ "team.title" | t(locale) }}</h1>
            <p class="section-subtitle">{{ "team.subtitle" | t(locale) }}</p>
        </div>
    </section>

    <section class="team-page-cards">
        <div class="container">
            <div class="flip-cards-grid">

                {# Axel Segers #}
                <div class="flip-card" tabindex="0" aria-label="Axel Segers">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <div class="flip-card-photo">
                                <img src="{{ "/assets/axel.webp" | withPathPrefix }}" alt="Axel Segers" width="2403" height="3600" loading="lazy" decoding="async">
                            </div>
                            <div class="flip-card-front-info">
                                <h2>Axel Segers</h2>
                                <p class="flip-card-role">{{ "team.axel.role" | t(locale) }}</p>
                            </div>
                        </div>
                        <div class="flip-card-back">
                            <h2>Axel Segers</h2>
                            <p class="flip-card-back-bio">{{ "team.axel.bio" | t(locale) }}</p>
                            <p class="flip-card-skills">{{ "team.axel.skills" | t(locale) }}</p>
                            <div class="flip-card-social">
                                <a href="https://www.linkedin.com/in/axelsegers/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
