<script>
(function() {
    var storageKey = 'sa-theme';
    var darkThemeColor = '#0f172a';
    var lightThemeColor = '#f1f5f9';
    var doc = document.documentElement;
    var savedTheme = null;

    try {
        savedTheme = window.localStorage.getItem(storageKey);
    } catch (error) {
        savedTheme = null;
    }

    // Default to dark mode unless the visitor explicitly chose light.
    var theme = savedTheme === 'light' ? 'light' : 'dark';

    doc.dataset.theme = theme;
    doc.style.colorScheme = theme;

    var themeColorMeta = document.querySelector('meta[name="theme-color"]');
    if (themeColorMeta) {
        themeColorMeta.setAttribute('content', theme === 'light' ? lightThemeColor : darkThemeColor);
    }
})();
</script>
