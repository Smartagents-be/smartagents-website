{% macro serviceHero(title, subtitle) %}
<section class="page-hero">
    <div class="container">
        <h1>{{ title }}</h1>
        <p>{{ subtitle }}</p>
    </div>
</section>
{% endmacro %}

{% macro pageSection(title, sectionClass='page-section', contentClass='page-vision-text') %}
<section class="{{ sectionClass }}">
    <div class="container">
        <h2 class="section-title">{{ title }}</h2>
        {% if contentClass %}
        <div class="{{ contentClass }}">
            {{ caller() }}
        </div>
        {% else %}
        {{ caller() }}
        {% endif %}
    </div>
</section>
{% endmacro %}

{% macro roleItem(title, description, kicker='') %}
<div class="page-role-item">
    <div class="page-role-icon">
        {{ caller() }}
    </div>
    <div>
        {% if kicker %}
        <span class="page-role-item-kicker">{{ kicker }}</span>
        {% endif %}
        <h3>{{ title }}</h3>
        <p>{{ description }}</p>
    </div>
</div>
{% endmacro %}

{% macro benefitCard(title, description) %}
<div class="page-benefit-card">
    <div class="page-benefit-icon">
        {{ caller() }}
    </div>
    <h3>{{ title }}</h3>
    <p>{{ description }}</p>
</div>
{% endmacro %}

{% macro deliverableCard(title, description) %}
<div class="scan-deliverable-card">
    <h3>{{ title }}</h3>
    <p>{{ description }}</p>
</div>
{% endmacro %}

{% macro scanProcessSection(title, sectionClass='page-section page-section-alt') %}
<section class="{{ sectionClass }}">
    <div class="container">
        <h2 class="section-title">{{ title }}</h2>
        <div class="scan-process">
            <div class="scan-process-line"></div>
            {{ caller() }}
        </div>
    </div>
</section>
{% endmacro %}

{% macro scanStep(side, number, title, description) %}
<div class="scan-step scan-step-{{ side }}">
    {% if side == 'right' %}
    <div class="scan-step-spacer"></div>
    {% endif %}
    {% if side == 'left' %}
    <div class="scan-step-content">
        <div class="scan-step-num">{{ number }}</div>
        <h3>{{ title }}</h3>
        <p>{{ description }}</p>
    </div>
    {% endif %}
    <div class="scan-step-node">
        {{ caller() }}
    </div>
    {% if side == 'left' %}
    <div class="scan-step-spacer"></div>
    {% endif %}
    {% if side == 'right' %}
    <div class="scan-step-content">
        <div class="scan-step-num">{{ number }}</div>
        <h3>{{ title }}</h3>
        <p>{{ description }}</p>
    </div>
    {% endif %}
</div>
{% endmacro %}

{% macro ctaSection(title, text, buttonText, href) %}
<section class="page-cta">
    <div class="container">
        <h2>{{ title }}</h2>
        <p>{{ text }}</p>
        <a href="{{ href }}" class="btn btn-primary">{{ buttonText }}</a>
    </div>
</section>
{% endmacro %}
