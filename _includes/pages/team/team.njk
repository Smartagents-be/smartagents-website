{% set nlUrl = nlPermalink %}
{% set enUrl = "/en" + nlPermalink %}
{% set nlAltUrl = nlUrl | absoluteUrl(baseUrl) %}
{% set enAltUrl = enUrl | absoluteUrl(baseUrl) %}
<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ "page.team.title" | t(locale) }}</title>
    <meta name="description" content="{{ 'page.team.description' | t(locale) }}">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#00d8ff">
    <link rel="canonical" href="{{ page.url | absoluteUrl(baseUrl) }}">
    <link rel="alternate" hreflang="nl" href="{{ nlAltUrl }}">
    <link rel="alternate" hreflang="en" href="{{ enAltUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ nlAltUrl }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="SmartAgents">
    {% set ogLocale = 'nl_BE' if locale == 'nl' else 'en_US' %}
    {% set ogLocaleAlt = 'en_US' if locale == 'nl' else 'nl_BE' %}
    {% set resolvedSocialImage = baseUrl + socialImage %}
    {% set resolvedSocialAlt = socialAlt[locale] %}
    <meta property="og:title" content="{{ 'page.team.title' | t(locale) }}">
    <meta property="og:description" content="{{ 'page.team.description' | t(locale) }}">
    <meta property="og:url" content="{{ page.url | absoluteUrl(baseUrl) }}">
    <meta property="og:locale" content="{{ ogLocale }}">
    <meta property="og:locale:alternate" content="{{ ogLocaleAlt }}">
    <meta property="og:image" content="{{ resolvedSocialImage }}">
    <meta property="og:image:alt" content="{{ resolvedSocialAlt }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ 'page.team.title' | t(locale) }}">
    <meta name="twitter:description" content="{{ 'page.team.description' | t(locale) }}">
    <meta name="twitter:image" content="{{ resolvedSocialImage }}">
    <meta name="twitter:image:alt" content="{{ resolvedSocialAlt }}">
    <meta name="twitter:domain" content="smartagents.be">
    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="stylesheet" href="/styles.css?v={{ assetsVersion }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Structured Data -->
    {% include "schema-organization.njk" %}
    {% set schemaData = { schemaType: schemaType, pageKey: pageKey, socialImage: socialImage, nlPermalink: nlPermalink, pageUrl: page.url } %}
    {% set schema = schemaData | buildSchema(locale) %}
    {% if schema %}
    <script type="application/ld+json" data-generated-schema="page">{{ schema | safe }}</script>
    {% endif %}
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18080961249"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18080961249');
    </script>
</head>
<body data-page="team">
    {% include "header.njk" %}

    <section class="team-page-hero">
        <div class="container">
            <h1 class="section-title">{{ "team.title" | t(locale) }}</h1>
            <p class="section-subtitle">{{ "team.subtitle" | t(locale) }}</p>
        </div>
    </section>

    <section class="team-page-cards">
        <div class="container">
            <div class="flip-cards-grid">

                {# Axel Segers #}
                <div class="flip-card" tabindex="0" aria-label="Axel Segers">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <div class="flip-card-photo">
                                <img src="/assets/axel.webp" alt="Axel Segers" width="560" height="700" loading="lazy" decoding="async">
                            </div>
                            <div class="flip-card-front-info">
                                <h2>Axel Segers</h2>
                                <p class="flip-card-role">{{ "team.axel.role" | t(locale) }}</p>
                            </div>
                        </div>
                        <div class="flip-card-back">
                            <h2>Axel Segers</h2>
                            <p class="flip-card-back-bio">{{ "team.axel.bio" | t(locale) }}</p>
                            <p class="flip-card-skills">{{ "team.axel.skills" | t(locale) }}</p>
                            <div class="flip-card-social">
                                <a href="https://www.linkedin.com/in/axelsegers/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                </a>
                                <a href="mailto:axel@smartagents.be" aria-label="Email">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Tom Haeldermans #}
                <div class="flip-card" tabindex="0" aria-label="Tom Haeldermans">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <div class="flip-card-photo">
                                <img src="/assets/tom.webp" alt="Tom Haeldermans" width="560" height="700" loading="lazy" decoding="async">
                            </div>
                            <div class="flip-card-front-info">
                                <h2>Tom Haeldermans</h2>
                                <p class="flip-card-role">{{ "team.tom.role" | t(locale) }}</p>
                            </div>
                        </div>
                        <div class="flip-card-back">
                            <h2>Tom Haeldermans</h2>
                            <p class="flip-card-back-bio">{{ "team.tom.bio" | t(locale) }}</p>
                            <p class="flip-card-skills">{{ "team.tom.skills" | t(locale) }}</p>
                            <div class="flip-card-social">
                                <a href="https://www.linkedin.com/in/tom-haeldermans-862172117/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                </a>
                                <a href="mailto:tom@smartagents.be" aria-label="Email">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {# Agents card #}
                <div class="flip-card flip-card--agents" tabindex="0" aria-label="{{ 'team.agents.name' | t(locale) }}">
                    <div class="flip-card-inner">
                        <div class="flip-card-front">
                            <div class="flip-card-photo flip-card-photo--agents">
                                <img src="/assets/agent-network.svg" alt="Agent network" width="560" height="700" loading="lazy" decoding="async">
                            </div>
                            <div class="flip-card-front-info">
                                <h2>{{ "team.agents.name" | t(locale) }}</h2>
                                <p class="flip-card-role">{{ "team.agents.role" | t(locale) }}</p>
                            </div>
                        </div>
                        <div class="flip-card-back flip-card-back--agents">
                            <h2>{{ "team.agents.name" | t(locale) }}</h2>
                            <p class="flip-card-back-bio">{{ "team.agents.bio" | t(locale) }}</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js?v={{ assetsVersion }}"></script>
</body>
</html>
