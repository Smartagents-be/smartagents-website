                        </svg>
                    </div>
                    <h3 class="gradient-text">{{ "mission.title" | t(locale) }}</h3>
                    <p class="vm-headline">{{ "mission.headline" | t(locale) }}</p>
                    <p class="vm-text">{{ "mission.text" | t(locale) }}</p>
