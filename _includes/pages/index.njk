    <section id="contact" class="contact">
        <div class="container">
            <h2 class="section-title">{{ "contact.title" | t(locale) }}</h2>
            <p class="section-subtitle">{{ "contact.subtitle" | t(locale) }}</p>

            <form class="contact-form" id="contact-form" action="https://formsubmit.co/info@smartagents.be" method="POST">
                <input type="hidden" name="_subject" value="{{ 'contact.form.subject' | t(locale) }}">
                <input type="hidden" name="_next" value="{{ baseUrl }}{{ "/" | locale_url }}#contact">
                <input type="hidden" name="_captcha" value="true">
                <input type="text" name="_honey" style="display:none">
                <div class="form-row">
                    <div class="form-group">
                        <label for="name">{{ "contact.form.name" | t(locale) }}</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">{{ "contact.form.email" | t(locale) }}</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="company">{{ "contact.form.company" | t(locale) }}</label>
                    <input type="text" id="company" name="company">
                </div>
                <div class="form-group">
                    <label for="message">{{ "contact.form.message" | t(locale) }}</label>
                    <textarea id="message" name="message" rows="5" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary"
                  data-label-default="{{ 'contact.form.submit' | t(locale) }}"
                  data-label-success="{{ 'contact.form.success' | t(locale) }}"
                  data-label-error="{{ 'contact.form.error' | t(locale) }}">
                  {{ "contact.form.submit" | t(locale) }}
                </button>
            </form>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js"></script>
</body>
