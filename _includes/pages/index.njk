{% set nlUrl = '/' %}
{% set enUrl = '/en/' %}
{% set nlAltUrl = nlUrl | absoluteUrl(baseUrl) %}
{% set enAltUrl = enUrl | absoluteUrl(baseUrl) %}
<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ "page.index.title" | t(locale) }}</title>
    <meta name="description" content="{{ 'page.index.description' | t(locale) }}">
    <meta name="author" content="SmartAgents">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#00d8ff">
    <link rel="canonical" href="{{ page.url | absoluteUrl(baseUrl) }}">
    <link rel="alternate" hreflang="nl" href="{{ nlAltUrl }}">
    <link rel="alternate" hreflang="en" href="{{ enAltUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ nlAltUrl }}">

    <!-- Open Graph -->
    {% set ogLocale = 'nl_BE' if locale == 'nl' else 'en_US' %}
    {% set ogLocaleAlt = 'en_US' if locale == 'nl' else 'nl_BE' %}
    {% set resolvedSocialImage = baseUrl + socialImage %}
    {% set resolvedSocialAlt = socialAlt[locale] %}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ 'page.index.title' | t(locale) }}">
    <meta property="og:description" content="{{ 'page.index.description' | t(locale) }}">
    <meta property="og:url" content="{{ page.url | absoluteUrl(baseUrl) }}">
    <meta property="og:image" content="{{ resolvedSocialImage }}">
    <meta property="og:image:alt" content="{{ resolvedSocialAlt }}">
    <meta property="og:locale" content="{{ ogLocale }}">
    <meta property="og:locale:alternate" content="{{ ogLocaleAlt }}">
    <meta property="og:site_name" content="SmartAgents">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ 'page.index.title' | t(locale) }}">
    <meta name="twitter:description" content="{{ 'page.index.description' | t(locale) }}">
    <meta name="twitter:image" content="{{ resolvedSocialImage }}">
    <meta name="twitter:image:alt" content="{{ resolvedSocialAlt }}">
    <meta name="twitter:domain" content="smartagents.be">

    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Structured Data -->
    {% include "schema-organization.njk" %}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "SmartAgents",
        "url": "https://smartagents.be"
    }
    </script>

    {% set schemaData = { schemaType: schemaType, pageKey: pageKey, socialImage: socialImage, nlPermalink: nlPermalink, pageUrl: page.url } %}
    {% set schema = schemaData | buildSchema(locale) %}
    {% if schema %}
    <script type="application/ld+json" data-generated-schema="page">{{ schema | safe }}</script>
    {% endif %}
</head>
<body class="index-page">
    {% include "header.njk" %}

    <header class="hero">
        <canvas id="hero-canvas"></canvas>
        <div class="hero-overlay"></div>

        <!-- Desktop hero: title + CTA -->
        <div class="hero-content hero-desktop-only">
            <h1>{{ "hero.title" | t(locale) | safe }}</h1>
            <p>{{ "hero.subtitle" | t(locale) }}</p>
            <div class="hero-cta">
                <a href="#contact" class="btn btn-primary">{{ "hero.cta.primary" | t(locale) }}</a>
                <a href="#services" class="btn btn-secondary">{{ "hero.cta.secondary" | t(locale) }}</a>
            </div>
        </div>

        <!-- Mobile hero: centered logo -->
        <div class="hero-centered-logo hero-animate hero-mobile-only">
            <svg class="logo-icon" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-label="SmartAgents" role="img">
                <defs>
                    <linearGradient id="heroLogoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#00d8ff"/>
                        <stop offset="50%" style="stop-color:#22d3ee"/>
                        <stop offset="100%" style="stop-color:#4f6cf7"/>
                    </linearGradient>
                </defs>
                <g stroke="url(#heroLogoGradient)" stroke-width="1.5" fill="none" opacity="0.6">
                    <line x1="24" y1="8" x2="12" y2="20"/>
                    <line x1="24" y1="8" x2="36" y2="20"/>
                    <line x1="12" y1="20" x2="24" y2="24"/>
                    <line x1="36" y1="20" x2="24" y2="24"/>
                    <line x1="12" y1="20" x2="12" y2="32"/>
                    <line x1="36" y1="20" x2="36" y2="32"/>
                    <line x1="24" y1="24" x2="24" y2="40"/>
                    <line x1="12" y1="32" x2="24" y2="40"/>
                    <line x1="36" y1="32" x2="24" y2="40"/>
                </g>
                <g fill="url(#heroLogoGradient)">
                    <circle cx="24" cy="8" r="4"/>
                    <circle cx="12" cy="20" r="3"/>
                    <circle cx="36" cy="20" r="3"/>
                    <circle cx="24" cy="24" r="3.5"/>
                    <circle cx="12" cy="32" r="2.5"/>
                    <circle cx="36" cy="32" r="2.5"/>
                    <circle cx="24" cy="40" r="3"/>
                </g>
                <circle cx="24" cy="8" r="6" fill="none" stroke="url(#heroLogoGradient)" stroke-width="1" opacity="0.4"/>
            </svg>
            <span class="hero-logo-wordmark"><span class="hero-word">Smart</span><span class="hero-word">Agents</span></span>
            <span class="hero-logo-tagline">{{ "footer.tagline" | t(locale) }}</span>
        </div>

        <div class="hero-scroll-hint hero-animate-delayed">
            <span>{{ "hero.scroll" | t(locale) }}</span>
            <svg viewBox="0 0 24 24" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
    </header>

    <section class="hero-intro hero-intro-mobile-only">
        <div class="container">
            <div class="hero-intro-inner">
                <div class="hero-intro-text">
                    <h1>{{ "hero.title" | t(locale) | safe }}</h1>
                    <p>{{ "hero.subtitle" | t(locale) }}</p>
                </div>
                <div class="hero-intro-stats">
                    <div class="hero-stat-card">
                        <div class="hero-stat-number"><span class="stat-number" data-target="25">0</span>+</div>
                        <div class="hero-stat-label">{{ "stats.agents" | t(locale) }}</div>
                    </div>
                    <div class="hero-stat-card">
                        <div class="hero-stat-number"><span class="stat-number" data-target="23">0</span>%</div>
                        <div class="hero-stat-label">{{ "stats.cost" | t(locale) }}</div>
                    </div>
                    <div class="hero-stat-card">
                        <div class="hero-stat-number"><span class="stat-number" data-target="98">0</span>%</div>
                        <div class="hero-stat-label">{{ "stats.satisfaction" | t(locale) }}</div>
                    </div>
                    <div class="hero-stat-card">
                        <div class="hero-stat-number"><span class="stat-number" data-target="24">0</span>/7</div>
                        <div class="hero-stat-label">{{ "stats.support" | t(locale) }}</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

