    <section class="aanpak page-section">
        <div class="container">
            <h2 class="section-title">{{ "approach.title" | t(locale) }}</h2>
            <p class="section-subtitle">{{ "approach.subtitle" | t(locale) }}</p>

            <div class="aanpak-timeline">
                <div class="aanpak-step">
                    <div class="aanpak-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="7"></circle>
                            <path d="M20 20l-3.5-3.5"></path>
                        </svg>
                    </div>
                    <div class="aanpak-number">01</div>
                    <h3>{{ "approach.step1.title" | t(locale) }}</h3>
                    <p>{{ "approach.step1.desc" | t(locale) }}</p>
                    <a href="{{ "/services/smart-scan/" | locale_url }}" class="aanpak-link">{{ "approach.step1.btn" | t(locale) }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
                </div>
                <div class="aanpak-step">
                    <div class="aanpak-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M3 21h6"></path>
