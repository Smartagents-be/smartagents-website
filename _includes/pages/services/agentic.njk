                </div>
                <div class="aanpak-step">
                    <div class="aanpak-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="6" y1="20" x2="6" y2="10"></line>
                            <line x1="12" y1="20" x2="12" y2="4"></line>
                            <line x1="18" y1="20" x2="18" y2="14"></line>
                        </svg>
                    </div>
                    <div class="aanpak-number">05</div>
                    <h3>{{ "approach.step5.title" | t(locale) }}</h3>
                    <p>{{ "approach.step5.desc" | t(locale) }}</p>
                </div>
            </div>
        </div>
