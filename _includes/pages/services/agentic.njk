    <section class="page-cta">
        <div class="container">
            <h2>{{ "services.agentic.page.cta.title" | t(locale) }}</h2>
            <p>{{ "services.agentic.page.cta.text" | t(locale) }}</p>
            <a href="{{ "/" | locale_url }}#contact" class="btn btn-primary">{{ "services.agentic.page.cta.button" | t(locale) }}</a>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js"></script>
</body>
</html>
