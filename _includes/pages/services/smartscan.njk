                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="page-cta">
        <div class="container">
            <h2>{{ "services.smartscan.page.cta.title" | t(locale) }}</h2>
            <p>{{ "services.smartscan.page.cta.text" | t(locale) }}</p>
            <a href="{{ "/" | locale_url }}#contact" class="btn btn-primary">{{ "services.smartscan.page.cta.button" | t(locale) }}</a>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js"></script>
</body>
</html>
