                            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                    </div>
                    <div>
                        <h3>{{ "services.smartscan.page.item5.title" | t(locale) }}</h3>
                        <p>{{ "services.smartscan.page.item5.desc" | t(locale) }}</p>
                    </div>
                </div>
