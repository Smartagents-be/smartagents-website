    <section class="page-section page-section-alt">
        <div class="container">
            <h2 class="section-title">{{ "services.smartscan.page.process.title" | t(locale) }}</h2>

            <div class="scan-process">
                <div class="scan-process-line"></div>

                <div class="scan-step scan-step-left">
                    <div class="scan-step-content">
                        <div class="scan-step-num">01</div>
