    <section class="page-cta">
        <div class="container">
            <h2>{{ "services.ontwerp.page.cta.title" | t(locale) }}</h2>
            <p>{{ "services.ontwerp.page.cta.text" | t(locale) }}</p>
            <a href="{{ "/" | locale_url }}#contact" class="btn btn-primary">{{ "services.ontwerp.page.cta.button" | t(locale) }}</a>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js?v=2"></script>
