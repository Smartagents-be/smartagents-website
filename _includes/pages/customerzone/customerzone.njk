{% set nlUrl = nlPermalink %}
{% set enUrl = "/en" + nlPermalink %}
{% set nlAltUrl = nlUrl | absoluteUrl(baseUrl) %}
{% set enAltUrl = enUrl | absoluteUrl(baseUrl) %}
<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ "page.customerzone.title" | t(locale) }}</title>
    <meta name="description" content="{{ 'page.customerzone.description' | t(locale) }}">
    <meta name="theme-color" content="#00d8ff">
    <meta name="robots" content="noindex, follow">
    <link rel="canonical" href="{{ page.url | absoluteUrl(baseUrl) }}">
    <link rel="alternate" hreflang="nl" href="{{ nlAltUrl }}">
    <link rel="alternate" hreflang="en" href="{{ enAltUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ nlAltUrl }}">
    <meta property="og:url" content="{{ page.url | absoluteUrl(baseUrl) }}">

    <!-- Open Graph -->
    {% set ogLocale = 'nl_BE' if locale == 'nl' else 'en_US' %}
    {% set ogLocaleAlt = 'en_US' if locale == 'nl' else 'nl_BE' %}
    {% set resolvedSocialImage = baseUrl + socialImage %}
    {% set resolvedSocialAlt = socialAlt[locale] %}
    <meta property="og:title" content="{{ 'page.customerzone.title' | t(locale) }}">
    <meta property="og:description" content="{{ 'page.customerzone.description' | t(locale) }}">
    <meta property="og:locale" content="{{ ogLocale }}">
    <meta property="og:locale:alternate" content="{{ ogLocaleAlt }}">
    <meta property="og:image" content="{{ resolvedSocialImage }}">
    <meta property="og:image:alt" content="{{ resolvedSocialAlt }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="SmartAgents">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ 'page.customerzone.title' | t(locale) }}">
    <meta name="twitter:description" content="{{ 'page.customerzone.description' | t(locale) }}">
    <meta name="twitter:image" content="{{ resolvedSocialImage }}">
    <meta name="twitter:image:alt" content="{{ resolvedSocialAlt }}">

    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="stylesheet" href="/styles.css?v=7">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            position: relative;
            overflow: hidden;
            background: var(--dark);
        }

        .login-content {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

        /* Dashboard Preview — absolute positioned panels around the centered login */
        .dashboard-preview {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            user-select: none;
        }

        .dashboard-panel {
            position: absolute;
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 24px;
            width: 280px;
            filter: blur(1.5px);
            opacity: 0.45;
            transition: opacity 0.3s;
        }

        /* Position panels around the login card */
        .dashboard-panel:nth-child(1) {
            top: 8%;
            left: 4%;
        }

        .dashboard-panel:nth-child(2) {
            top: 6%;
            right: 4%;
        }

        .dashboard-panel:nth-child(3) {
            bottom: 8%;
            left: 5%;
        }

        .dashboard-panel:nth-child(4) {
            bottom: 10%;
            right: 5%;
        }

        .panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--light);
        }

        .panel-header .panel-icon {
            margin-right: 8px;
        }

        .panel-header .panel-badge {
            background: var(--cyan-15);
            color: var(--cyan);
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        /* Panel 1: Agent Status */
        .agent-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .agent-row:last-child {
            border-bottom: none;
        }

        .agent-name {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #22c55e;
            box-shadow: 0 0 6px rgba(34, 197, 94, 0.6);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }

        .agent-status {
            color: #22c55e;
            font-size: 0.75rem;
            font-weight: 500;
        }

        /* Panel 2: Stats Overview */
        .stats-grid {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--cyan);
            -webkit-text-fill-color: var(--cyan);
        }

        .stat-label {
            font-size: 0.7rem;
            color: rgba(255, 255, 255, 0.45);
            margin-top: 2px;
        }

        .bar-chart {
            display: flex;
            align-items: flex-end;
            gap: 4px;
            height: 36px;
        }

        .bar-chart .bar {
            flex: 1;
            border-radius: 3px 3px 0 0;
            background: var(--cyan);
            opacity: 0.5;
        }

        /* Panel 3: Recent Activity */
        .activity-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 7px 0;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.65);
        }

        .activity-icon {
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        .activity-icon.done {
            color: #22c55e;
        }

        .activity-icon.pending {
            color: var(--cyan);
            animation: spin 2s linear infinite;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Panel 4: Performance */
        .perf-row {
            margin-bottom: 16px;
        }

        .perf-row:last-child {
            margin-bottom: 0;
        }

        .perf-label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 8px;
        }

        .perf-change {
            color: #22c55e;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .progress-bar {
            height: 8px;
            background: rgba(255, 255, 255, 0.06);
            border-radius: 4px;
            overflow: hidden;
        }

        .progress-bar .progress-fill {
            height: 100%;
            border-radius: 4px;
            background: var(--cyan);
        }

        /* Login Card — always centered */
        .login-card {
            background: var(--dark-lighter);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 48px 40px;
            width: 100%;
            max-width: 420px;
            position: relative;
            z-index: 3;
        }

        .login-logo {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 12px;
            font-size: 1.75rem;
            font-weight: 700;
        }

        .login-logo .logo-text {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .login-logo span {
            color: var(--cyan);
            -webkit-text-fill-color: var(--cyan);
            letter-spacing: -0.5px;
        }

        .login-logo .logo-tagline {
            font-size: 0.55rem;
            font-weight: 400;
            -webkit-text-fill-color: var(--gray-light);
            letter-spacing: 0.5px;
        }

        .login-logo img {
            width: 36px;
            height: 36px;
        }

        .login-subtitle {
            text-align: center;
            color: var(--gray-light);
            margin-bottom: 40px;
            font-size: 0.95rem;
        }

        .login-card .form-group {
            margin-bottom: 20px;
        }

        .login-card .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--gray-light);
            font-weight: 500;
        }

        .login-card .form-group input {
            width: 100%;
            padding: 14px 18px;
            background: var(--dark);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            color: var(--light);
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s ease;
        }

        .login-card .form-group input:focus {
            outline: none;
            border-color: var(--cyan);
        }

        .login-btn {
            width: 100%;
            margin-top: 8px;
        }

        .login-error {
            color: #ef4444;
            text-align: center;
            margin-top: 16px;
            font-size: 0.9rem;
            display: none;
        }

        .login-back {
            text-align: center;
            margin-top: 24px;
        }

        .login-back a {
            color: var(--gray-light);
            font-size: 0.9rem;
            transition: color 0.3s ease;
        }

        .login-back a:hover {
            color: var(--cyan);
        }

        .login-overlay {
            position: absolute;
            inset: 0;
            z-index: 0;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .dashboard-panel {
                width: 240px;
                padding: 18px;
            }
        }

        @media (max-width: 768px) {
            .dashboard-preview {
                display: none;
            }
        }

        @media (max-width: 480px) {
            .login-card {
                padding: 36px 24px;
            }
        }
    </style>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18080961249"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'AW-18080961249');
    </script>
</head>
<body>
    <h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">{{ "page.customerzone.title" | t(locale) }}</h1>
    <div class="login-page">
        <canvas id="hero-canvas" class="login-overlay"></canvas>
        <div class="hero-overlay" style="position:absolute;inset:0;z-index:1;background:linear-gradient(135deg,rgba(15,23,42,0.85),rgba(15,23,42,0.75));"></div>
        <div class="login-content">
            <!-- Dashboard Preview (decorative, aria-hidden)
                 These panels show sample data to illustrate the customer zone UI.
                 Text is intentionally kept in English as universal product/demo language. -->
            <div class="dashboard-preview" aria-hidden="true">
                <!-- Panel 1: Agent Status -->
                <div class="dashboard-panel">
                    <div class="panel-header">
                        <span><span class="panel-icon">🤖</span>Active Agents</span>
                        <span class="panel-badge">3/3</span>
                    </div>
                    <div class="agent-row">
                        <span class="agent-name"><span class="status-dot"></span>Billing Agent</span>
                        <span class="agent-status">Online</span>
                    </div>
                    <div class="agent-row">
                        <span class="agent-name"><span class="status-dot"></span>Customer Service Bot</span>
                        <span class="agent-status">Online</span>
                    </div>
                    <div class="agent-row">
                        <span class="agent-name"><span class="status-dot"></span>Data Analysis Agent</span>
                        <span class="agent-status">Online</span>
                    </div>
                </div>

                <!-- Panel 2: Stats Overview -->
                <div class="dashboard-panel">
                    <div class="panel-header">
                        <span><span class="panel-icon">📊</span>This Month</span>
                    </div>
                    <div class="stats-grid">
                        <div class="stat-item">
                            <div class="stat-value">1.247</div>
                            <div class="stat-label">Tasks</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">€23.4K</div>
                            <div class="stat-label">Saved</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">98.7%</div>
                            <div class="stat-label">Uptime</div>
                        </div>
                    </div>
                    <div class="bar-chart">
                        <div class="bar" style="height:25%"></div>
                        <div class="bar" style="height:45%"></div>
                        <div class="bar" style="height:65%"></div>
                        <div class="bar" style="height:85%"></div>
                        <div class="bar" style="height:100%"></div>
                        <div class="bar" style="height:75%"></div>
                        <div class="bar" style="height:50%"></div>
                        <div class="bar" style="height:60%"></div>
                        <div class="bar" style="height:90%"></div>
                        <div class="bar" style="height:100%"></div>
                    </div>
                </div>

                <!-- Panel 3: Recent Activity -->
                <div class="dashboard-panel">
                    <div class="panel-header">
                        <span><span class="panel-icon">🕐</span>Recent Activity</span>
                    </div>
                    <div class="activity-item">
                        <span class="activity-icon done">✓</span>
                        <span>14 invoices processed</span>
                    </div>
                    <div class="activity-item">
                        <span class="activity-icon done">✓</span>
                        <span>Q4 report generated</span>
                    </div>
                    <div class="activity-item">
                        <span class="activity-icon done">✓</span>
                        <span>3 new leads qualified</span>
                    </div>
                    <div class="activity-item">
                        <span class="activity-icon pending">⟳</span>
                        <span>Monthly report in progress...</span>
                    </div>
                </div>

                <!-- Panel 4: Performance -->
                <div class="dashboard-panel">
                    <div class="panel-header">
                        <span><span class="panel-icon">⚡</span>Performance</span>
                    </div>
                    <div class="perf-row">
                        <div class="perf-label">
                            <span>Efficiency</span>
                            <span class="perf-change">+12% ↑</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:84%"></div>
                        </div>
                    </div>
                    <div class="perf-row">
                        <div class="perf-label">
                            <span>Customer Satisfaction</span>
                            <span class="perf-change">+5% ↑</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width:93%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Login Card -->
            <div class="login-card">
                <div class="login-logo">
                    <img src="/assets/logo.svg" alt="SmartAgents logo" width="36" height="36" decoding="async">
                    <div class="logo-text">
                        <span>SmartAgents</span>
                        <small class="logo-tagline">{{ "footer.tagline" | t(locale) }}</small>
                    </div>
                </div>
                <p class="login-subtitle">{{ "customerzone.subtitle" | t(locale) }}</p>
                <form id="login-form">
                    <div class="form-group">
                        <label for="username">{{ "customerzone.username" | t(locale) }}</label>
                        <input type="text" id="username" name="username" required autocomplete="username">
                    </div>
                    <div class="form-group">
                        <label for="password">{{ "customerzone.password" | t(locale) }}</label>
                        <input type="password" id="password" name="password" required autocomplete="current-password">
                    </div>
                    <button type="submit" class="btn btn-primary login-btn">{{ "customerzone.login" | t(locale) }}</button>
                    <p class="login-error" id="login-error">{{ "customerzone.error" | t(locale) }}</p>
                </form>
                <div class="login-back">
                    <a href="{{ "/" | locale_url }}">{{ "customerzone.back" | t(locale) | safe }}</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Neural network canvas animation (same as main site)
        (function() {
            const canvas = document.getElementById('hero-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');

            const colors = [
                { r: 99, g: 102, b: 241 },
                { r: 14, g: 165, b: 233 },
                { r: 139, g: 92, b: 246 }
            ];

            let width, height, nodes, dpr;
            const CONNECTION_DIST = 150;

            function resize() {
                dpr = window.devicePixelRatio || 1;
                var parent = canvas.parentElement;
                width = parent.clientWidth;
                height = parent.clientHeight;
                canvas.width = width * dpr;
                canvas.height = height * dpr;
                canvas.style.width = width + 'px';
                canvas.style.height = height + 'px';
                ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            }

            function createNodes() {
                var isMobile = window.innerWidth < 768;
                var count = isMobile ? 30 : 60;
                nodes = [];
                for (var i = 0; i < count; i++) {
                    var color = colors[Math.floor(Math.random() * colors.length)];
                    nodes.push({
                        x: Math.random() * width,
                        y: Math.random() * height,
                        vx: (Math.random() - 0.5) * 0.4,
                        vy: (Math.random() - 0.5) * 0.4,
                        radius: Math.random() * 2 + 1.5,
                        color: color,
                        pulse: Math.random() * Math.PI * 2
                    });
                }
            }

            function draw() {
                ctx.clearRect(0, 0, width, height);
                for (var i = 0; i < nodes.length; i++) {
                    for (var j = i + 1; j < nodes.length; j++) {
                        var dx = nodes[i].x - nodes[j].x;
                        var dy = nodes[i].y - nodes[j].y;
                        var dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < CONNECTION_DIST) {
                            var alpha = (1 - dist / CONNECTION_DIST) * 0.3;
                            var c = nodes[i].color;
                            ctx.strokeStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + alpha + ')';
                            ctx.lineWidth = 1;
                            ctx.beginPath();
                            ctx.moveTo(nodes[i].x, nodes[i].y);
                            ctx.lineTo(nodes[j].x, nodes[j].y);
                            ctx.stroke();
                        }
                    }
                }
                for (var i = 0; i < nodes.length; i++) {
                    var n = nodes[i];
                    n.pulse += 0.02;
                    var pulseSize = Math.sin(n.pulse) * 0.5 + 0.5;
                    var c = n.color;
                    ctx.beginPath();
                    ctx.arc(n.x, n.y, n.radius + 4 + pulseSize * 3, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',0.08)';
                    ctx.fill();
                    ctx.beginPath();
                    ctx.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + (0.6 + pulseSize * 0.4) + ')';
                    ctx.fill();
                }
            }

            function update() {
                for (var i = 0; i < nodes.length; i++) {
                    var n = nodes[i];
                    n.x += n.vx;
                    n.y += n.vy;
                    if (n.x < 0 || n.x > width) n.vx *= -1;
                    if (n.y < 0 || n.y > height) n.vy *= -1;
                }
            }

            function animate() {
                update();
                draw();
                requestAnimationFrame(animate);
            }

            function init() {
                resize();
                createNodes();
                animate();
            }

            if (document.readyState === 'complete') {
                init();
            } else {
                window.addEventListener('load', init);
            }

            window.addEventListener('resize', function() {
                resize();
                createNodes();
            });
        })();

        // Login form handling
        document.getElementById('login-form').addEventListener('submit', function(e) {
            e.preventDefault();
            document.getElementById('login-error').style.display = 'block';
        });
    </script>
</body>
</html>
