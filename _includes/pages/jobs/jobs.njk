{% set nlUrl = nlPermalink %}
{% set enUrl = "/en" + nlPermalink %}
{% set nlAltUrl = nlUrl | absoluteUrl(baseUrl) %}
{% set enAltUrl = enUrl | absoluteUrl(baseUrl) %}
<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ "page.jobs.title" | t(locale) }}</title>
    <meta name="description" content="{{ 'page.jobs.description' | t(locale) }}">
    <meta name="robots" content="index, follow">
    <meta name="theme-color" content="#00d8ff">
    <link rel="canonical" href="{{ page.url | absoluteUrl(baseUrl) }}">
    <link rel="alternate" hreflang="nl" href="{{ nlAltUrl }}">
    <link rel="alternate" hreflang="en" href="{{ enAltUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ nlAltUrl }}">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="SmartAgents">
    {% set ogLocale = 'nl_BE' if locale == 'nl' else 'en_US' %}
    {% set ogLocaleAlt = 'en_US' if locale == 'nl' else 'nl_BE' %}
    {% set resolvedSocialImage = baseUrl + socialImage %}
    {% set resolvedSocialAlt = socialAlt[locale] %}
    <meta property="og:title" content="{{ 'page.jobs.title' | t(locale) }}">
    <meta property="og:description" content="{{ 'page.jobs.description' | t(locale) }}">
    <meta property="og:url" content="{{ page.url | absoluteUrl(baseUrl) }}">
    <meta property="og:locale" content="{{ ogLocale }}">
    <meta property="og:locale:alternate" content="{{ ogLocaleAlt }}">
    <meta property="og:image" content="{{ resolvedSocialImage }}">
    <meta property="og:image:alt" content="{{ resolvedSocialAlt }}">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ 'page.jobs.title' | t(locale) }}">
    <meta name="twitter:description" content="{{ 'page.jobs.description' | t(locale) }}">
    <meta name="twitter:image" content="{{ resolvedSocialImage }}">
    <meta name="twitter:image:alt" content="{{ resolvedSocialAlt }}">
    <meta name="twitter:domain" content="smartagents.be">
    <link rel="icon" type="image/svg+xml" href="/assets/logo.svg">
    <link rel="stylesheet" href="/styles.css?v=6">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Structured Data -->
    {% include "schema-organization.njk" %}
    {% set schemaData = { schemaType: schemaType, pageKey: pageKey, socialImage: socialImage, nlPermalink: nlPermalink, pageUrl: page.url, postedDate: postedDate } %}
    {% set schema = schemaData | buildSchema(locale) %}
    {% if schema %}
    <script type="application/ld+json" data-generated-schema="page">{{ schema | safe }}</script>
    {% endif %}
</head>
<body data-page="jobs">
    {% include "header.njk" %}

    <section class="page-hero">
        <div class="container">
            <div class="page-hero-badge">
                <span class="page-hero-badge-dot"></span>
                {{ "jobs.hero.badge" | t(locale) }}
            </div>
            <h1>{{ "jobs.hero.title" | t(locale) | safe }}</h1>
            <p>{{ "jobs.hero.subtitle" | t(locale) }}</p>
        </div>
    </section>

    <section class="page-section">
        <div class="container">
            <h2 class="section-title">{{ "jobs.vision.title" | t(locale) }}</h2>
            <div class="page-vision-text">
                <p>{{ "jobs.vision.text" | t(locale) }}</p>
            </div>
        </div>
    </section>

    <section class="page-section page-section-alt">
        <div class="container">
            <h2 class="section-title">{{ "jobs.vacancies.title" | t(locale) }}</h2>

            <div class="jc" id="jobsCarousel">
                <div class="jc-track">

                    <!-- Slide 1: Agentic AI Developer -->
                    <div class="jc-slide jc-slide--active" data-accent="cyan">
                        <div class="jc-slide-inner">
                            <div class="jc-slide-header">
                                <div class="jobs-vacancy-tag jobs-vacancy-tag--cyan">
                                    <span class="jobs-vacancy-dot"></span>
                                    {{ "jobs.hero.badge" | t(locale) }}
                                </div>
                                <h3 class="jc-slide-title">{{ "jobs.role.title" | t(locale) }}</h3>
                                <p class="jc-slide-subtitle">{{ "jobs.role.subtitle" | t(locale) }}</p>
                            </div>
                            <div class="page-role-grid">
                                <div class="page-role-item">
                                    <div class="page-role-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role.item1.title" | t(locale) }}</h3><p>{{ "jobs.role.item1.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role.item2.title" | t(locale) }}</h3><p>{{ "jobs.role.item2.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role.item3.title" | t(locale) }}</h3><p>{{ "jobs.role.item3.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role.item4.title" | t(locale) }}</h3><p>{{ "jobs.role.item4.desc" | t(locale) }}</p></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Slide 2: Business Analyst -->
                    <div class="jc-slide" data-accent="purple">
                        <div class="jc-slide-inner">
                            <div class="jc-slide-header">
                                <div class="jobs-vacancy-tag jobs-vacancy-tag--purple">
                                    <span class="jobs-vacancy-dot"></span>
                                    {{ "jobs.hero.badge" | t(locale) }}
                                </div>
                                <h3 class="jc-slide-title">{{ "jobs.role2.title" | t(locale) }}</h3>
                                <p class="jc-slide-subtitle">{{ "jobs.role2.subtitle" | t(locale) }}</p>
                            </div>
                            <div class="page-role-grid">
                                <div class="page-role-item">
                                    <div class="page-role-icon page-role-icon--purple">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role2.item1.title" | t(locale) }}</h3><p>{{ "jobs.role2.item1.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon page-role-icon--purple">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role2.item2.title" | t(locale) }}</h3><p>{{ "jobs.role2.item2.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon page-role-icon--purple">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role2.item3.title" | t(locale) }}</h3><p>{{ "jobs.role2.item3.desc" | t(locale) }}</p></div>
                                </div>
                                <div class="page-role-item">
                                    <div class="page-role-icon page-role-icon--purple">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                                    </div>
                                    <div><h3>{{ "jobs.role2.item4.title" | t(locale) }}</h3><p>{{ "jobs.role2.item4.desc" | t(locale) }}</p></div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Controls -->
                <div class="jc-controls">
                    <button class="jc-btn jc-prev" aria-label="Vorige vacature">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <div class="jc-dots">
                        <button class="jc-dot jc-dot--active" data-slide="0" aria-label="Vacature 1"></button>
                        <button class="jc-dot" data-slide="1" aria-label="Vacature 2"></button>
                    </div>
                    <button class="jc-btn jc-next" aria-label="Volgende vacature">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>
                </div>
            </div>

            <p class="jc-freelance-note">{{ "jobs.vacancies.freelance" | t(locale) }}</p>
        </div>
    </section>

    <section class="page-section">
        <div class="container">
            <h2 class="section-title">{{ "jobs.benefits.title" | t(locale) }}</h2>
            <div class="page-benefits-grid">
                <div class="page-benefit-card">
                    <div class="page-benefit-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                        </svg>
                    </div>
                    <h3>{{ "jobs.benefit1.title" | t(locale) }}</h3>
                    <p>{{ "jobs.benefit1.desc" | t(locale) }}</p>
                </div>
                <div class="page-benefit-card">
                    <div class="page-benefit-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                    </div>
                    <h3>{{ "jobs.benefit2.title" | t(locale) }}</h3>
                    <p>{{ "jobs.benefit2.desc" | t(locale) }}</p>
                </div>
                <div class="page-benefit-card">
                    <div class="page-benefit-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                    </div>
                    <h3>{{ "jobs.benefit3.title" | t(locale) }}</h3>
                    <p>{{ "jobs.benefit3.desc" | t(locale) }}</p>
                </div>
                <div class="page-benefit-card">
                    <div class="page-benefit-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    </div>
                    <h3>{{ "jobs.benefit4.title" | t(locale) }}</h3>
                    <p>{{ "jobs.benefit4.desc" | t(locale) }}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="page-section page-section-alt jobs-team">
        <div class="container">
            <h2 class="section-title">{{ "jobs.team.title" | t(locale) }}</h2>

            <div class="jt-founders">

                <!-- Axel -->
                <div class="jt-founder">
                    <div class="jt-photo-wrap">
                        <img src="/assets/axel.webp" alt="Axel Segers" class="jt-photo">
                        <div class="jt-photo-glow jt-photo-glow--cyan"></div>
                    </div>
                    <div class="jt-founder-body">
                        <div class="jt-founder-header">
                            <h3>Axel Segers</h3>
                            <span class="jt-role">{{ "team.axel.role" | t(locale) }}</span>
                        </div>
                        <p class="jt-bio">{{ "team.axel.bio" | t(locale) }}</p>
                        <div class="jt-chips">
                            <span class="jt-chip">Strategie &amp; Visie</span>
                            <span class="jt-chip">Digitale Transformatie</span>
                            <span class="jt-chip">25+ jaar</span>
                        </div>
                    </div>
                </div>

                <!-- Divider -->
                <div class="jt-divider" aria-hidden="true">
                    <div class="jt-divider-line"></div>
                    <div class="jt-divider-node">
                        <svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                            <g stroke="currentColor" stroke-width="1.5" fill="none" opacity="0.6">
                                <line x1="24" y1="8" x2="12" y2="20"/><line x1="24" y1="8" x2="36" y2="20"/>
                                <line x1="12" y1="20" x2="24" y2="24"/><line x1="36" y1="20" x2="24" y2="24"/>
                                <line x1="12" y1="20" x2="12" y2="32"/><line x1="36" y1="20" x2="36" y2="32"/>
                                <line x1="24" y1="24" x2="24" y2="40"/><line x1="12" y1="32" x2="24" y2="40"/><line x1="36" y1="32" x2="24" y2="40"/>
                            </g>
                            <g fill="currentColor">
                                <circle cx="24" cy="8" r="4"/><circle cx="12" cy="20" r="3"/><circle cx="36" cy="20" r="3"/>
                                <circle cx="24" cy="24" r="3.5"/><circle cx="12" cy="32" r="2.5"/><circle cx="36" cy="32" r="2.5"/><circle cx="24" cy="40" r="3"/>
                            </g>
                        </svg>
                    </div>
                    <div class="jt-divider-line"></div>
                </div>

                <!-- Tom -->
                <div class="jt-founder">
                    <div class="jt-photo-wrap">
                        <img src="/assets/tom.webp" alt="Tom Haeldermans" class="jt-photo">
                        <div class="jt-photo-glow jt-photo-glow--purple"></div>
                    </div>
                    <div class="jt-founder-body">
                        <div class="jt-founder-header">
                            <h3>Tom Haeldermans</h3>
                            <span class="jt-role">{{ "team.tom.role" | t(locale) }}</span>
                        </div>
                        <p class="jt-bio">{{ "team.tom.bio" | t(locale) }}</p>
                        <div class="jt-chips">
                            <span class="jt-chip jt-chip--purple">Agentic AI</span>
                            <span class="jt-chip jt-chip--purple">Enterprise Architectuur</span>
                            <span class="jt-chip jt-chip--purple">Tech Lead</span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- Team DNA strip -->
            <div class="jt-dna">
                <div class="jt-dna-item">
                    <span class="jt-dna-val">{{ "jobs.team.promise1.val" | t(locale) }}</span>
                    <span class="jt-dna-sub">{{ "jobs.team.promise1.sub" | t(locale) }}</span>
                </div>
                <div class="jt-dna-sep"></div>
                <div class="jt-dna-item">
                    <span class="jt-dna-val">{{ "jobs.team.promise2.val" | t(locale) }}</span>
                    <span class="jt-dna-sub">{{ "jobs.team.promise2.sub" | t(locale) }}</span>
                </div>
                <div class="jt-dna-sep"></div>
                <div class="jt-dna-item">
                    <span class="jt-dna-val">{{ "jobs.team.promise3.val" | t(locale) }}</span>
                    <span class="jt-dna-sub">{{ "jobs.team.promise3.sub" | t(locale) }}</span>
                </div>
            </div>

        </div>
    </section>

    <section class="page-cta">
        <div class="container">
            <h2>{{ "jobs.cta.title" | t(locale) }}</h2>
            <p>{{ "jobs.cta.text" | t(locale) }}</p>
            <div class="page-cta-contacts">
                <a href="mailto:axel@smartagents.be">axel@smartagents.be</a>
                <span class="page-cta-divider">|</span>
                <a href="mailto:tom@smartagents.be">tom@smartagents.be</a>
            </div>
            <a href="{{ "/" | locale_url }}#contact" class="btn btn-primary page-cta-btn">{{ "jobs.cta.button" | t(locale) }}</a>
        </div>
    </section>

    {% include "footer.njk" %}

    <script src="/main.js?v=2"></script>
</body>
</html>
